#!/bin/bash
set -Eeuo pipefail
# shellcheck disable=SC2034

# shellcheck source=/dev/null
source /usr/local/emhttp/plugins/zfs.autosnapshot/scripts/ops-queue-lib.sh

WORKER_ROLE="send"
WORKER_LOCK_DIR=""
CURRENT_JOB_ID=""
CURRENT_JOB_PATH=""
CURRENT_ACTIVE_DATASETS_FILE=""
CURRENT_PREP_POOL=""
CURRENT_SPACE_RESERVATION_JOB_ID=""
CURRENT_SEND_TRANSFER_SLOT_DIR=""
SEND_JOB_ID_CACHE_LOADED=0
declare -A SEND_JOB_ID_PATH_CACHE=()

SEND_CHILD_JOB_WRITE_KEYS=(
  JOB_ID JOB_TYPE JOB_MODE JOB_ACTION STATE PHASE REQUESTED_EPOCH REQUESTED_AT QUEUE_SORT
  WINDOW_KEY RUN_GROUP_ID PREP_JOB_ID PREP_DEST_POOL SCHEDULE_JOB_ID PARENT_RUN_ID MEMBER_INDEX
  SOURCE_ROOT DESTINATION_ROOT INCLUDE_CHILDREN FREQUENCY THRESHOLD THRESHOLD_BYTES
  SNAPSHOT_PREFIX_BASE SNAPSHOT_PREFIX SOURCE_SNAPSHOT SOURCE_SNAPSHOT_NAME PREVIOUS_SNAPSHOT_NAME
  ATTEMPT_COUNT RETRY_AT LAST_ERROR LAST_MESSAGE
  WORKER_PID PROGRESS_PERCENT MEMBER_COUNT MEMBER_0_SOURCE MEMBER_0_DESTINATION MEMBER_0_SNAPSHOT
  COMPLETES_SCHEDULE_WINDOW
)

SEND_FINALIZE_JOB_WRITE_KEYS=(
  JOB_ID JOB_TYPE JOB_MODE JOB_ACTION STATE PHASE REQUESTED_EPOCH REQUESTED_AT QUEUE_SORT
  WINDOW_KEY SCHEDULE_JOB_ID PARENT_RUN_ID SOURCE_ROOT DESTINATION_ROOT SNAPSHOT_PREFIX
  SOURCE_SNAPSHOT_NAME PREVIOUS_SNAPSHOT_NAME ATTEMPT_COUNT RETRY_AT LAST_ERROR LAST_MESSAGE
  WORKER_PID PROGRESS_PERCENT COMPLETES_SCHEDULE_WINDOW
)

cleanup() {
  local exit_code="$?"
  if [[ -n "$CURRENT_JOB_ID" ]]; then
    release_job_claim "$CURRENT_JOB_ID"
  fi
  if [[ -n "$CURRENT_PREP_POOL" ]]; then
    release_pool_prep_lock "$CURRENT_PREP_POOL"
    CURRENT_PREP_POOL=""
  fi
  release_current_space_reservation
  release_current_send_transfer_slot
  clear_active_send_datasets
  rm -rf "$WORKER_LOCK_DIR" >/dev/null 2>&1 || true
  exit "$exit_code"
}

persist_job() {
  job_write "$CURRENT_JOB_PATH" job
}

set_job_progress() {
  local phase="$1"
  local percent="$2"
  local message="$3"
  job[STATE]="running"
  job[PHASE]="$phase"
  job[PROGRESS_PERCENT]="$percent"
  job[LAST_MESSAGE]="$message"
  job[WORKER_PID]="$$"
  persist_job
}

complete_job() {
  local message="$1"
  local ttl="${2:-$JOB_SUCCESS_TTL_SECONDS}"
  job[STATE]="complete"
  job[PHASE]="complete"
  job[PROGRESS_PERCENT]="100"
  job[LAST_MESSAGE]="$message"
  job[LAST_ERROR]=""
  job[WORKER_PID]=""
  if [[ "$(job_get job JOB_MODE)" == "scheduled" ]] && job_completes_schedule_window job; then
    record_completed_schedule_window "$(job_get job SCHEDULE_JOB_ID)" "$(job_get job WINDOW_KEY)" || true
  fi
  set_job_success_purge_after job "$ttl"
  delete_preserved_failed_send_log "$(job_get job JOB_ID)" >/dev/null 2>&1 || true
  persist_job
}

skip_job() {
  local message="$1"
  job[STATE]="skipped"
  job[PHASE]="complete"
  job[PROGRESS_PERCENT]="100"
  job[LAST_MESSAGE]="$message"
  job[LAST_ERROR]=""
  job[WORKER_PID]=""
  set_job_success_purge_after job
  delete_preserved_failed_send_log "$(job_get job JOB_ID)" >/dev/null 2>&1 || true
  persist_job
}

fail_current_job() {
  local message="$1"
  local now_epoch
  now_epoch="$(date +%s)"
  mark_job_failed_or_retry job "$message" "$now_epoch"
  persist_job || true
}

fail_current_job_final() {
  local message="$1"
  job[STATE]="failed"
  job[PHASE]="failed"
  job[RETRY_AT]="0"
  job[PROGRESS_PERCENT]="100"
  job[WORKER_PID]=""
  job[LAST_ERROR]="$message"
  job[LAST_MESSAGE]="$message"
  preserve_failed_send_log_for_job job || true
  persist_job || true
}

defer_current_job() {
  local message="$1"
  local delay="${2:-15}"
  local now_epoch
  now_epoch="$(date +%s)"
  job[STATE]="retry_wait"
  job[PHASE]="retry_wait"
  job[RETRY_AT]="$((now_epoch + delay))"
  job[WORKER_PID]=""
  job[LAST_MESSAGE]="$message"
  persist_job
}

release_current_prep_pool_lock() {
  if [[ -n "$CURRENT_PREP_POOL" ]]; then
    release_pool_prep_lock "$CURRENT_PREP_POOL"
    CURRENT_PREP_POOL=""
  fi
}

release_current_space_reservation() {
  if [[ -n "$CURRENT_SPACE_RESERVATION_JOB_ID" ]]; then
    release_send_space_reservation_for_job "$CURRENT_SPACE_RESERVATION_JOB_ID"
    CURRENT_SPACE_RESERVATION_JOB_ID=""
  fi
}

release_current_send_transfer_slot() {
  if [[ -n "$CURRENT_SEND_TRANSFER_SLOT_DIR" ]]; then
    release_send_transfer_slot "$CURRENT_SEND_TRANSFER_SLOT_DIR"
    CURRENT_SEND_TRANSFER_SLOT_DIR=""
  fi
}

clear_active_send_datasets() {
  if [[ -n "$CURRENT_ACTIVE_DATASETS_FILE" ]]; then
    rm -f "$CURRENT_ACTIVE_DATASETS_FILE" >/dev/null 2>&1 || true
    CURRENT_ACTIVE_DATASETS_FILE=""
  fi
}

effective_job_action() {
  local assoc_name="$1"
  # shellcheck disable=SC2178
  local -n job_ref="$assoc_name"
  local action

  action="${job_ref[JOB_ACTION]:-}"
  if [[ -n "$action" ]]; then
    printf '%s' "$action"
    return 0
  fi

  if [[ "${job_ref[JOB_ID]:-}" == finalize-* ]]; then
    printf 'finalize'
    return 0
  fi

  if [[ -n "${job_ref[PARENT_RUN_ID]:-}" && -n "${job_ref[MEMBER_INDEX]:-}" ]]; then
    printf 'send_member'
    return 0
  fi

  printf 'prepare'
}

register_active_send_datasets_for_current_job() {
  local mode action source_root include_children dataset file tmp source_dataset

  clear_active_send_datasets
  mkdir -p "$ACTIVE_SEND_DATASETS_DIR" >/dev/null 2>&1 || true
  file="${ACTIVE_SEND_DATASETS_DIR}/worker-$$-$(printf '%s' "$CURRENT_JOB_ID" | tr -c 'A-Za-z0-9._-' '_').datasets"
  tmp="${file}.tmp"
  : > "$tmp"

  mode="$(job_get job JOB_MODE)"
  action="$(effective_job_action job)"
  case "$mode:$action" in
    scheduled:send_member)
      dataset="$(job_get job SOURCE_ROOT)"
      [[ -n "$dataset" ]] && printf '%s\n' "$dataset" >> "$tmp"
      ;;
    scheduled:prepare|scheduled:single_send|scheduled:)
      source_root="$(job_get job SOURCE_ROOT)"
      include_children="$(job_get job INCLUDE_CHILDREN 0)"
      while IFS= read -r source_dataset; do
        [[ -n "$source_dataset" ]] || continue
        printf '%s\n' "$source_dataset" >> "$tmp"
      done < <(list_tree_datasets "$source_root" "$include_children")
      ;;
    manual_snapshot:*)
      dataset="$(job_get job DATASET)"
      [[ -n "$dataset" ]] && printf '%s\n' "$dataset" >> "$tmp"
      ;;
  esac

  chmod 0600 "$tmp" >/dev/null 2>&1 || true
  mv -f "$tmp" "$file"
  CURRENT_ACTIVE_DATASETS_FILE="$file"
}

wait_for_autosnapshot_to_finish() {
  local mode message

  mode="$(job_get job JOB_MODE)"
  message="Waiting for autosnapshot."
  if [[ "$mode" == "manual_snapshot" ]]; then
    message="Waiting for autosnapshot."
  fi

  while autosnapshot_run_active; do
    set_job_progress "preparing" "10" "$message"
    sleep 5
  done
}

wait_for_unraid_array_to_be_actionable_for_current_job() {
  local mode suffix current_message last_message=""

  mode="$(job_get job JOB_MODE)"
  suffix="Waiting for array."
  if [[ "$mode" == "manual_snapshot" ]]; then
    suffix="Waiting for array."
  fi

  while ! unraid_array_actionable; do
    current_message="$(unraid_array_action_message). ${suffix}"
    if [[ "$current_message" != "$last_message" ]]; then
      log "$current_message"
      last_message="$current_message"
    fi
    set_job_progress "preparing" "5" "$suffix"
    sleep 5
  done
}

wait_for_unraid_array_to_be_actionable_for_send_queue() {
  local current_message last_message=""

  while ! unraid_array_actionable; do
    current_message="$(unraid_array_action_message). Send queue is paused."
    if [[ "$current_message" != "$last_message" ]]; then
      log "$current_message"
      last_message="$current_message"
    fi
    sleep 5
  done
}

ensure_delete_worker_for_backlog() {
  if delete_queue_has_backlog; then
    start_delete_queue_daemon >/dev/null 2>&1 || true
  fi
}

send_space_buffer_bytes() {
  local required_bytes="$1"
  local max_buffer=$((10 * 1024 * 1024 * 1024))
  local buffer

  [[ "$required_bytes" =~ ^[0-9]+$ ]] || required_bytes=0
  (( required_bytes > 0 )) || {
    printf '0'
    return 0
  }

  buffer=$(( required_bytes / 10 ))
  (( buffer <= max_buffer )) || buffer="$max_buffer"
  printf '%s' "$buffer"
}

rerun_space_cleanup_for_waiting_send() {
  local schedule_job_id="$1"
  local dest_pool="$2"
  local capacity_dataset="$3"
  local target_bytes="$4"
  local cleanup_started cleanup_elapsed
  # shellcheck disable=SC2034
  local -A planned_reclaim=()

  [[ -n "$schedule_job_id" && -n "$dest_pool" && -n "$capacity_dataset" ]] || return 1
  [[ "$target_bytes" =~ ^[0-9]+$ ]] || return 1

  if ! acquire_pool_prep_lock "$dest_pool"; then
    return 1
  fi
  CURRENT_PREP_POOL="$dest_pool"

  cleanup_started="$(date +%s)"
  log "Destination space reservation is short on pool ${dest_pool}; rerunning retention and low-space cleanup planning up to ${target_bytes} bytes."
  queue_pool_retention_cleanup "$dest_pool" "$capacity_dataset" planned_reclaim || true
  queue_pool_free_space_cleanup_for_target "$dest_pool" "$capacity_dataset" "$target_bytes" planned_reclaim || true
  cleanup_elapsed=$(( $(date +%s) - cleanup_started ))
  log "Reservation-triggered cleanup planning for pool ${dest_pool} completed in ${cleanup_elapsed}s"
  release_current_prep_pool_lock
  ensure_delete_worker_for_backlog
}

reserve_destination_space_for_current_send() {
  local destination="$1"
  local base_snapshot="$2"
  local snapshot="$3"
  local required_bytes buffer_bytes needed_bytes available_bytes capacity_dataset dest_pool schedule_job_id threshold_bytes cleanup_target transfer_slot_dir

  destination="${destination:-}"
  snapshot="${snapshot:-}"
  [[ -n "$destination" && -n "$snapshot" ]] || return 1

  capacity_dataset="$(nearest_existing_dataset_ancestor "$destination")"
  [[ -n "$capacity_dataset" ]] || capacity_dataset="${destination%%/*}"
  dest_pool="${capacity_dataset%%/*}"
  schedule_job_id="$(job_get job SCHEDULE_JOB_ID)"

  estimate_destination_space_for_current_send "$destination" "$base_snapshot" "$snapshot" || return 1
  required_bytes="$(job_get job SPACE_REQUIRED_BYTES 0)"

  buffer_bytes="$(send_space_buffer_bytes "$required_bytes")"
  if earlier_send_job_waiting_for_pool "$dest_pool"; then
    defer_current_job "Waiting turn on ${dest_pool}."
    return 2
  fi

  if ! acquire_send_transfer_slot "$CURRENT_JOB_ID" "$$" transfer_slot_dir; then
    defer_current_job "Waiting for send slot."
    return 2
  fi
  CURRENT_SEND_TRANSFER_SLOT_DIR="$transfer_slot_dir"

  if acquire_send_space_reservation "$CURRENT_JOB_ID" "$$" "$destination" "$capacity_dataset" "$required_bytes" "$buffer_bytes" available_bytes needed_bytes; then
    CURRENT_SPACE_RESERVATION_JOB_ID="$CURRENT_JOB_ID"
    log "Reserved destination space for ${CURRENT_JOB_ID}: destination=${destination} required=${required_bytes} buffer=${buffer_bytes} available_after_existing_reservations=${available_bytes}"
    return 0
  fi

  [[ "$needed_bytes" =~ ^[0-9]+$ ]] || needed_bytes=$(( required_bytes + buffer_bytes ))
  [[ "$available_bytes" =~ ^[0-9]+$ ]] || available_bytes=0
  if ! pool_has_active_delete_jobs "$dest_pool"; then
    release_current_send_transfer_slot
    cleanup_target="$needed_bytes"
    threshold_bytes="$(job_get job THRESHOLD_BYTES 0)"
    if [[ "$threshold_bytes" =~ ^[0-9]+$ ]] && (( threshold_bytes > cleanup_target )); then
      cleanup_target="$threshold_bytes"
    fi
    rerun_space_cleanup_for_waiting_send "$schedule_job_id" "$dest_pool" "$capacity_dataset" "$cleanup_target" || true
    if ! acquire_send_transfer_slot "$CURRENT_JOB_ID" "$$" transfer_slot_dir; then
      defer_current_job "Waiting for send slot."
      return 2
    fi
    CURRENT_SEND_TRANSFER_SLOT_DIR="$transfer_slot_dir"
    if acquire_send_space_reservation "$CURRENT_JOB_ID" "$$" "$destination" "$capacity_dataset" "$required_bytes" "$buffer_bytes" available_bytes needed_bytes; then
      CURRENT_SPACE_RESERVATION_JOB_ID="$CURRENT_JOB_ID"
      log "Reserved destination space for ${CURRENT_JOB_ID} after cleanup planning: destination=${destination} required=${required_bytes} buffer=${buffer_bytes} available_after_existing_reservations=${available_bytes}"
      return 0
    fi
  fi

  release_current_send_transfer_slot
  defer_current_job "Waiting for destination space."
  return 2
}

earlier_send_job_waiting_for_pool() {
  local dest_pool="$1"
  local current_sort other_sort file state action other_dest other_pool other_job_id
  local -A other_job=()

  current_sort="$(job_get job QUEUE_SORT 0)"
  [[ "$current_sort" =~ ^[0-9]+$ ]] || current_sort=0

  while IFS= read -r file; do
    # shellcheck disable=SC2034
    other_job=()
    job_load "$file" other_job || continue
    [[ "$(job_get other_job JOB_TYPE)" == "send" ]] || continue
    other_job_id="$(job_get other_job JOB_ID)"
    [[ "$other_job_id" != "$CURRENT_JOB_ID" ]] || continue
    action="$(job_get other_job JOB_ACTION)"
    case "$action" in
      send_member|"")
        ;;
      *)
        continue
        ;;
    esac
    state="$(job_get other_job STATE)"
    case "$state" in
      queued|retry_wait)
        ;;
      running)
        send_space_reservation_exists_for_job "$other_job_id" && continue
        ;;
      *)
        continue
        ;;
    esac
    other_dest="$(job_get other_job DESTINATION_ROOT)"
    [[ -n "$other_dest" ]] || continue
    other_pool="${other_dest%%/*}"
    [[ "$other_pool" == "$dest_pool" ]] || continue
    other_sort="$(job_get other_job QUEUE_SORT 0)"
    [[ "$other_sort" =~ ^[0-9]+$ ]] || other_sort=0
    if (( other_sort < current_sort )); then
      return 0
    fi
  done < <(list_job_files)

  return 1
}

estimate_destination_space_for_current_send() {
  local destination="$1"
  local base_snapshot="$2"
  local snapshot="$3"
  local required_bytes cached_key expected_key

  expected_key="${base_snapshot}|${snapshot}|${destination}"
  cached_key="$(job_get job SPACE_ESTIMATE_KEY)"
  required_bytes="$(job_get job SPACE_REQUIRED_BYTES 0)"
  if [[ "$cached_key" == "$expected_key" && "$required_bytes" =~ ^[0-9]+$ ]]; then
    return 0
  fi

  job[LAST_MESSAGE]="Calculating needed space."
  persist_job || true
  required_bytes="$(estimate_zfs_send_stream_bytes "$base_snapshot" "$snapshot")"
  [[ "$required_bytes" =~ ^[0-9]+$ ]] || required_bytes=0
  job[SPACE_ESTIMATE_KEY]="$expected_key"
  job[SPACE_REQUIRED_BYTES]="$required_bytes"
  job[LAST_MESSAGE]="Space estimate ready."
  persist_job || true
  log "Estimated destination space for ${CURRENT_JOB_ID}: destination=${destination} snapshot=${snapshot} base=${base_snapshot:-none} required=${required_bytes}"
}

wait_for_pool_prep_for_current_job() {
  local prep_job_id prep_path prep_state prep_message
  # shellcheck disable=SC2034
  local -A prep_job=()

  prep_job_id="$(job_get job PREP_JOB_ID)"
  [[ -n "$prep_job_id" ]] || return 0

  if ! find_job_by_id "$prep_job_id" prep_path; then
    log "Pool prep job ${prep_job_id} is no longer present; treating it as completed for ${CURRENT_JOB_ID}."
    return 0
  fi

  job_load "$prep_path" prep_job || return 0
  prep_state="$(job_get prep_job STATE)"
  case "$prep_state" in
    complete|skipped)
      return 0
      ;;
    failed)
      prep_message="$(job_get prep_job LAST_ERROR)"
      [[ -n "$prep_message" ]] || prep_message="$(job_get prep_job LAST_MESSAGE)"
      fail_current_job_final "Destination pool prep '${prep_job_id}' failed. ${prep_message}"
      return 1
      ;;
    queued|running|retry_wait)
      defer_current_job "Waiting for pool prep."
      return 2
      ;;
  esac

  return 0
}

run_pipeline_with_space_reservation() {
  local description="$1"
  local base_snapshot="$2"
  local snapshot="$3"
  local destination="$4"
  local send_progress="${5:-}"
  local rc

  estimate_destination_space_for_current_send "$destination" "$base_snapshot" "$snapshot" || return 1
  wait_for_pool_prep_for_current_job || return $?
  reserve_destination_space_for_current_send "$destination" "$base_snapshot" "$snapshot" || return $?
  if [[ -n "$send_progress" ]]; then
    set_job_progress "sending" "$send_progress" "Sending."
  fi
  if run_pipeline_with_status "$description" "$base_snapshot" "$snapshot" "$destination"; then
    rc=0
  else
    rc=$?
  fi
  release_current_space_reservation
  release_current_send_transfer_slot
  return "$rc"
}

schedule_run_base_sort() {
  local requested_epoch="$1"
  [[ "$requested_epoch" =~ ^[0-9]+$ ]] || requested_epoch=0
  printf '%s' $(( requested_epoch * 100000 ))
}

send_member_sort_key() {
  local base_sort="$1"
  local index="$2"
  printf '%s' $(( base_sort + 100 + (index * 10) ))
}

finalize_sort_key() {
  local base_sort="$1"
  printf '%s' $(( base_sort + 90000 ))
}

find_existing_job_path_by_id() {
  local job_id="$1"
  local result_var="$2"
  local file
  # shellcheck disable=SC2034
  local -A existing_job=()

  printf -v "$result_var" ''
  while IFS= read -r file; do
    job_load "$file" existing_job || continue
    if [[ "$(job_get existing_job JOB_ID)" == "$job_id" ]]; then
      printf -v "$result_var" '%s' "$file"
      return 0
    fi
  done < <(list_job_files)

  return 1
}

load_existing_send_job_id_cache() {
  local file job_id
  # shellcheck disable=SC2034
  local -A existing_job=()

  (( SEND_JOB_ID_CACHE_LOADED == 1 )) && return 0

  SEND_JOB_ID_PATH_CACHE=()
  while IFS= read -r file; do
    # shellcheck disable=SC2034
    existing_job=()
    job_load "$file" existing_job || continue
    job_id="$(job_get existing_job JOB_ID)"
    [[ -n "$job_id" ]] || continue
    SEND_JOB_ID_PATH_CACHE["$job_id"]="$file"
  done < <(list_job_files)

  SEND_JOB_ID_CACHE_LOADED=1
}

write_send_job_file() {
  local path="$1"
  local assoc_name="$2"
  # shellcheck disable=SC2178
  local -n send_job_ref="$assoc_name"

  case "${send_job_ref[JOB_ACTION]:-}" in
    send_member)
      job_write_ordered "$path" "$assoc_name" "${SEND_CHILD_JOB_WRITE_KEYS[@]}"
      ;;
    finalize)
      job_write_ordered "$path" "$assoc_name" "${SEND_FINALIZE_JOB_WRITE_KEYS[@]}"
      ;;
    *)
      job_write "$path" "$assoc_name"
      ;;
  esac
}

ensure_send_job_file() {
  local assoc_name="$1"
  local requested_epoch="$2"
  local path job_id
  # shellcheck disable=SC2178
  local -n send_job_ref="$assoc_name"

  job_id="${send_job_ref[JOB_ID]:-}"
  [[ -n "$job_id" ]] || return 1

  path="${OPS_JOBS_DIR}/$(printf '%010d-%s.job' "$requested_epoch" "$job_id")"
  if [[ -f "$path" ]]; then
    return 0
  fi

  load_existing_send_job_id_cache
  if [[ -n "${SEND_JOB_ID_PATH_CACHE[$job_id]:-}" ]]; then
    return 0
  fi

  [[ -f "$path" ]] && return 0
  write_send_job_file "$path" "$assoc_name" || return 1
  SEND_JOB_ID_PATH_CACHE["$job_id"]="$path"
  return 0
}

prepare_scheduled_job_snapshot() {
  local basename source_root include_children create_cmd previous_basename=""

  source_root="$(job_get job SOURCE_ROOT)"
  include_children="$(job_get job INCLUDE_CHILDREN 0)"

  if [[ -n "$(job_get job SOURCE_SNAPSHOT)" ]]; then
    if ! snapshot_exists "$(job_get job SOURCE_SNAPSHOT)"; then
      fail_current_job_final "Scheduled send snapshot '$(job_get job SOURCE_SNAPSHOT)' is no longer available."
      return 1
    fi
    build_members_for_job job "$(job_get job SOURCE_SNAPSHOT_NAME)"
    persist_job
    return 0
  fi

  latest_checkpoint_basename_for_schedule "$(job_get job SCHEDULE_JOB_ID)" previous_basename
  job[PREVIOUS_SNAPSHOT_NAME]="$previous_basename"

  basename="$(job_get job SNAPSHOT_PREFIX)$(date +%Y-%m-%d_%H-%M-%S)"
  if [[ "$include_children" == "1" ]]; then
    create_cmd=(zfs snapshot -r "${source_root}@${basename}")
  else
    create_cmd=(zfs snapshot "${source_root}@${basename}")
  fi

  log "Creating scheduled send checkpoint ${source_root}@${basename}"
  "${create_cmd[@]}"

  job[SOURCE_SNAPSHOT]="${source_root}@${basename}"
  job[SOURCE_SNAPSHOT_NAME]="$basename"
  job[SOURCE_SNAPSHOT_EPOCH]="$(date +%s)"
  build_members_for_job job "$basename"
  persist_job
  return 0
}

prepare_manual_snapshot_job() {
  local snapshot dataset destination
  snapshot="$(job_get job SOURCE_SNAPSHOT)"
  dataset="$(job_get job DATASET)"
  destination="$(job_get job DESTINATION_ROOT)"

  if ! snapshot_exists "$snapshot"; then
    fail_current_job_final "Snapshot '${snapshot}' is no longer available for manual send."
    return 1
  fi

  job[SOURCE_ROOT]="$dataset"
  job[DESTINATION_ROOT]="$destination"
  job[INCLUDE_CHILDREN]="0"
  job[MEMBER_COUNT]="1"
  job[MEMBER_0_SOURCE]="$dataset"
  job[MEMBER_0_DESTINATION]="$destination"
  job[MEMBER_0_SNAPSHOT]="$snapshot"
  persist_job
  return 0
}

build_resume_members_for_current_job() {
  local source_root dest_root include_children basename source_dataset destination_dataset relative
  local member_index=0
  local needs_resume=0

  source_root="$(job_get job SOURCE_ROOT)"
  dest_root="$(job_get job DESTINATION_ROOT)"
  include_children="$(job_get job INCLUDE_CHILDREN 0)"
  basename="$(job_get job SOURCE_SNAPSHOT_NAME)"

  [[ -n "$source_root" && -n "$dest_root" && -n "$basename" ]] || return 1
  source_snapshot_exists_for_basename "$source_root" "$basename" || return 1

  while IFS= read -r source_dataset; do
    [[ -n "$source_dataset" ]] || continue
    if [[ "$source_dataset" == "$source_root" ]]; then
      destination_dataset="$dest_root"
    else
      relative="${source_dataset#"${source_root}"/}"
      destination_dataset="${dest_root}/${relative}"
    fi

    if dataset_has_snapshot_basename "$destination_dataset" "$basename"; then
      continue
    fi

    source_snapshot_exists_for_basename "$source_dataset" "$basename" || return 1

    job[MEMBER_${member_index}_SOURCE]="$source_dataset"
    job[MEMBER_${member_index}_DESTINATION]="$destination_dataset"
    job[MEMBER_${member_index}_SNAPSHOT]="${source_dataset}@${basename}"
    member_index=$((member_index + 1))
    needs_resume=1
  done < <(list_tree_datasets "$source_root" "$include_children")

  job[MEMBER_COUNT]="$member_index"
  if (( needs_resume == 0 )); then
    job[LAST_MESSAGE]="Queueing finalizer."
  else
    job[LAST_MESSAGE]="Queueing missing sends."
  fi
  persist_job
  return 0
}

queue_child_send_jobs() {
  local member_count requested_epoch base_sort snapshot_basename schedule_job_id prefix previous_basename run_root_id
  local requested_at window_key frequency threshold threshold_bytes snapshot_prefix_base source_root destination_root completes_schedule_window
  local run_group_id prep_job_id prep_dest_pool
  local index source_dataset destination_dataset snapshot sort_key child_job_id finalize_job_id fanout_started fanout_elapsed
  # shellcheck disable=SC2034
  local -A queued_job=()
  local resume_only=0

  fanout_started="$(date +%s)"
  member_count="$(job_get job MEMBER_COUNT 0)"
  [[ "$member_count" =~ ^[0-9]+$ ]] || member_count=0
  resume_only="$(job_get job RESUME_ONLY 0)"
  [[ "$resume_only" == "1" ]] || resume_only=0
  if (( member_count <= 0 )) && (( resume_only == 0 )); then
    return 1
  fi

  requested_epoch="$(job_get job REQUESTED_EPOCH 0)"
  [[ "$requested_epoch" =~ ^[0-9]+$ ]] || requested_epoch="$(date +%s)"
  base_sort="$(schedule_run_base_sort "$requested_epoch")"
  snapshot_basename="$(job_get job SOURCE_SNAPSHOT_NAME)"
  schedule_job_id="$(job_get job SCHEDULE_JOB_ID)"
  prefix="$(job_get job SNAPSHOT_PREFIX)"
  previous_basename="$(job_get job PREVIOUS_SNAPSHOT_NAME)"
  run_root_id="$(job_get job JOB_ID)"
  requested_at="$(job_get job REQUESTED_AT)"
  window_key="$(job_get job WINDOW_KEY)"
  frequency="$(job_get job FREQUENCY)"
  threshold="$(job_get job THRESHOLD)"
  threshold_bytes="$(job_get job THRESHOLD_BYTES)"
  snapshot_prefix_base="$(job_get job SNAPSHOT_PREFIX_BASE)"
  source_root="$(job_get job SOURCE_ROOT)"
  destination_root="$(job_get job DESTINATION_ROOT)"
  completes_schedule_window="$(job_get job COMPLETES_SCHEDULE_WINDOW 1)"
  run_group_id="$(job_get job RUN_GROUP_ID)"
  prep_job_id="$(job_get job PREP_JOB_ID)"
  prep_dest_pool="$(job_get job PREP_DEST_POOL)"

  for ((index = 0; index < member_count; index++)); do
    source_dataset="$(job_get job MEMBER_${index}_SOURCE)"
    destination_dataset="$(job_get job MEMBER_${index}_DESTINATION)"
    snapshot="$(job_get job MEMBER_${index}_SNAPSHOT)"
    [[ -n "$source_dataset" && -n "$destination_dataset" && -n "$snapshot" ]] || continue

    sort_key="$(send_member_sort_key "$base_sort" "$index")"
    child_job_id="send-child-${run_root_id}-${index}"
    queued_job=()
    queued_job[JOB_ID]="$child_job_id"
    queued_job[JOB_TYPE]="send"
    queued_job[JOB_MODE]="scheduled"
    queued_job[JOB_ACTION]="send_member"
    queued_job[STATE]="queued"
    queued_job[PHASE]="queued"
    queued_job[REQUESTED_EPOCH]="$requested_epoch"
    queued_job[REQUESTED_AT]="$requested_at"
    queued_job[QUEUE_SORT]="$sort_key"
    queued_job[WINDOW_KEY]="$window_key"
    queued_job[RUN_GROUP_ID]="$run_group_id"
    queued_job[PREP_JOB_ID]="$prep_job_id"
    queued_job[PREP_DEST_POOL]="$prep_dest_pool"
    queued_job[SCHEDULE_JOB_ID]="$schedule_job_id"
    queued_job[PARENT_RUN_ID]="$run_root_id"
    queued_job[MEMBER_INDEX]="$index"
    queued_job[SOURCE_ROOT]="$source_dataset"
    queued_job[DESTINATION_ROOT]="$destination_dataset"
    queued_job[INCLUDE_CHILDREN]="0"
    queued_job[FREQUENCY]="$frequency"
    queued_job[THRESHOLD]="$threshold"
    queued_job[THRESHOLD_BYTES]="$threshold_bytes"
    queued_job[SNAPSHOT_PREFIX_BASE]="$snapshot_prefix_base"
    queued_job[SNAPSHOT_PREFIX]="$prefix"
    queued_job[SOURCE_SNAPSHOT]="$snapshot"
    queued_job[SOURCE_SNAPSHOT_NAME]="$snapshot_basename"
    queued_job[PREVIOUS_SNAPSHOT_NAME]="$previous_basename"
    queued_job[ATTEMPT_COUNT]="0"
    queued_job[RETRY_AT]="0"
    queued_job[LAST_ERROR]=""
    if (( resume_only == 1 )); then
      queued_job[LAST_MESSAGE]="Queued send."
    else
      queued_job[LAST_MESSAGE]="Queued send."
    fi
    queued_job[WORKER_PID]=""
    queued_job[PROGRESS_PERCENT]="5"
    queued_job[MEMBER_COUNT]="1"
    queued_job[MEMBER_0_SOURCE]="$source_dataset"
    queued_job[MEMBER_0_DESTINATION]="$destination_dataset"
    queued_job[MEMBER_0_SNAPSHOT]="$snapshot"
    queued_job[COMPLETES_SCHEDULE_WINDOW]="0"
    ensure_send_job_file queued_job "$requested_epoch" || return 1
  done

  finalize_job_id="finalize-${run_root_id}"
  queued_job=()
  queued_job[JOB_ID]="$finalize_job_id"
  queued_job[JOB_TYPE]="send"
  queued_job[JOB_MODE]="scheduled"
  queued_job[JOB_ACTION]="finalize"
  queued_job[STATE]="queued"
  queued_job[PHASE]="queued"
  queued_job[REQUESTED_EPOCH]="$requested_epoch"
  queued_job[REQUESTED_AT]="$requested_at"
  queued_job[QUEUE_SORT]="$(finalize_sort_key "$base_sort")"
  queued_job[WINDOW_KEY]="$window_key"
  queued_job[SCHEDULE_JOB_ID]="$schedule_job_id"
  queued_job[PARENT_RUN_ID]="$run_root_id"
  queued_job[SOURCE_ROOT]="$source_root"
  queued_job[DESTINATION_ROOT]="$destination_root"
  queued_job[SNAPSHOT_PREFIX]="$prefix"
  queued_job[SOURCE_SNAPSHOT_NAME]="$snapshot_basename"
  queued_job[PREVIOUS_SNAPSHOT_NAME]="$previous_basename"
  queued_job[ATTEMPT_COUNT]="0"
  queued_job[RETRY_AT]="0"
  queued_job[LAST_ERROR]=""
  if (( resume_only == 1 )); then
    queued_job[LAST_MESSAGE]="Waiting for children."
  else
    queued_job[LAST_MESSAGE]="Waiting for children."
  fi
  queued_job[WORKER_PID]=""
  queued_job[PROGRESS_PERCENT]="5"
  # shellcheck disable=SC2034
  queued_job[COMPLETES_SCHEDULE_WINDOW]="$completes_schedule_window"
  ensure_send_job_file queued_job "$requested_epoch" || return 1

  fanout_elapsed=$(( $(date +%s) - fanout_started ))
  log "Queued ${member_count} child send job(s) for ${run_root_id} in ${fanout_elapsed}s"
  return 0
}

send_member_snapshot() {
  local member_index="$1"
  local member_count="$2"
  local source_dataset destination snapshot basename latest_common description progress failure_message
  local destination_parent source_exists=0 destination_exists=0 parent_exists=0
  local source_type="" destination_type=""

  source_dataset="$(job_get job MEMBER_"${member_index}"_SOURCE)"
  destination="$(job_get job MEMBER_"${member_index}"_DESTINATION)"
  snapshot="$(job_get job MEMBER_"${member_index}"_SNAPSHOT)"
  basename="${snapshot##*@}"
  destination_parent="${destination%/*}"

  is_valid_dataset_name "$source_dataset" || {
    fail_current_job_final "Source dataset '${source_dataset}' is invalid."
    return 1
  }
  is_valid_dataset_name "$destination" || {
    fail_current_job_final "Destination dataset '${destination}' is invalid."
    return 1
  }
  is_valid_snapshot_name "$snapshot" || {
    fail_current_job_final "Snapshot '${snapshot}' is invalid."
    return 1
  }

  if dataset_exists "$source_dataset"; then
    source_exists=1
    source_type="$(dataset_type "$source_dataset")"
  fi
  if dataset_exists "$destination"; then
    destination_exists=1
    destination_type="$(dataset_type "$destination")"
  fi
  if [[ -n "$destination_parent" ]] && dataset_exists "$destination_parent"; then
    parent_exists=1
  fi

  log "Send preflight: source=${source_dataset} source_exists=${source_exists} source_type=${source_type:-unknown} destination=${destination} destination_exists=${destination_exists} destination_type=${destination_type:-missing} parent=${destination_parent} parent_exists=${parent_exists} snapshot=${snapshot} job_mode=$(job_get job JOB_MODE) job_action=$(effective_job_action job)"

  if ! ensure_destination_parent_exists "$destination"; then
    fail_current_job_final "Unable to ensure destination parent exists for '${destination}'."
    return 1
  fi

  if snapshot_exists "${destination}@${basename}"; then
    log "Destination already has ${destination}@${basename}; skipping receive for this member."
    return 0
  fi

  progress=$((30 + (member_index * 40 / (member_count == 0 ? 1 : member_count))))
  set_job_progress "preparing" "$progress" "Preparing send."

  if [[ "$(job_get job JOB_MODE)" == "scheduled" ]]; then
    latest_common=""
    find_latest_common_basename_for_member "$source_dataset" "$destination" "$(job_get job SNAPSHOT_PREFIX)" latest_common
    log "Scheduled send base selection: source=${source_dataset} destination=${destination} requested_snapshot=${basename} latest_common=${latest_common:-none}"
    if [[ -n "$latest_common" && "$latest_common" != "$basename" ]]; then
      is_valid_snapshot_basename "$latest_common" || {
        fail_current_job_final "Base snapshot '${latest_common}' is invalid."
        return 1
      }
      description="Incremental send ${source_dataset}@${latest_common} -> ${source_dataset}@${basename} -> ${destination}"
      run_pipeline_with_space_reservation "$description" "${source_dataset}@${latest_common}" "$snapshot" "$destination" "$progress" || return $?
    else
      if (( destination_exists == 1 )) && dataset_has_any_snapshots "$destination"; then
        failure_message="No common send checkpoint remains between '${source_dataset}' and '${destination}'. The destination dataset was purged so the next retry can reseed this backup from scratch. Review the preserved send log for diagnostics."
        log "$failure_message"
        if purge_destination_for_reseed "$destination"; then
          job[LAST_ERROR]="$failure_message"
          job[LAST_MESSAGE]="$failure_message"
          preserve_failed_send_log_for_job job || true
          fail_current_job "$failure_message"
          return 1
        fi
        fail_current_job_final "No common send checkpoint remains between '${source_dataset}' and '${destination}', and automatic destination purge for reseed failed."
        return 1
      fi
      description="Full send ${snapshot} -> ${destination}"
      run_pipeline_with_space_reservation "$description" "" "$snapshot" "$destination" "$progress" || return $?
    fi
  else
    latest_common=""
    find_latest_common_snapshot_for_target "$source_dataset" "$destination" "$basename" latest_common
    log "Manual send base selection: source=${source_dataset} destination=${destination} requested_snapshot=${basename} latest_common=${latest_common:-none}"
    if [[ -n "$latest_common" && "$latest_common" != "$basename" ]]; then
      is_valid_snapshot_basename "$latest_common" || {
        fail_current_job_final "Base snapshot '${latest_common}' is invalid."
        return 1
      }
      description="Manual incremental send ${source_dataset}@${latest_common} -> ${source_dataset}@${basename} -> ${destination}"
      run_pipeline_with_space_reservation "$description" "${source_dataset}@${latest_common}" "$snapshot" "$destination" "$progress" || return $?
    else
      if (( destination_exists == 1 )) && dataset_has_any_snapshots "$destination"; then
        failure_message="No common snapshot remains between '${source_dataset}' and '${destination}', and a destructive automatic reseed is not available for this manual send. Review the send log and re-seed the destination manually."
        fail_current_job_final "$failure_message"
        return 1
      fi
      description="Manual full send ${snapshot} -> ${destination}"
      run_pipeline_with_space_reservation "$description" "" "$snapshot" "$destination" "$progress" || return $?
    fi
  fi

  set_job_progress "verifying" "$((progress + 15))" "Verifying receive."
  snapshot_exists "${destination}@${basename}"
}

cleanup_source_checkpoints_for_verified_member() {
  local schedule_job_id source_dataset destination current_basename retained_basename retained_epoch
  local snap_name snap_epoch snap_base prefix schedule_count candidate_job_id
  local -A old_basenames=()

  schedule_job_id="$(job_get job SCHEDULE_JOB_ID)"
  current_basename="$(job_get job SOURCE_SNAPSHOT_NAME)"
  [[ -n "$current_basename" ]] || return 0

  source_dataset="$(job_get job SOURCE_ROOT)"
  destination="$(job_get job DESTINATION_ROOT)"
  [[ -n "$schedule_job_id" && -n "$source_dataset" && -n "$destination" ]] || return 0
  dataset_exists "$source_dataset" || return 0
  prefix="$(job_prefix_for_schedule "$schedule_job_id")"

  retained_basename=""
  find_latest_common_basename_for_member "$source_dataset" "$destination" "$prefix" retained_basename || true
  [[ -n "$retained_basename" ]] || {
    log "Skipping source checkpoint cleanup for ${source_dataset}; no common checkpoint with ${destination} was found."
    return 0
  }

  retained_epoch=0
  while IFS=$'\t' read -r snap_name snap_epoch; do
    [[ -n "$snap_name" && -n "$snap_epoch" ]] || continue
    [[ "${snap_name##*@}" == "$retained_basename" ]] || continue
    retained_epoch="$snap_epoch"
    break
  done < <(zfs list -H -p -t snapshot -o name,creation -d 1 "$source_dataset" 2>/dev/null || true)
  if ! [[ "$retained_epoch" =~ ^[0-9]+$ ]] || (( retained_epoch <= 0 )); then
    log "Skipping source checkpoint cleanup for ${source_dataset}; retained checkpoint ${retained_basename} is not available on the source."
    return 0
  fi

  while IFS=$'\t' read -r snap_name snap_epoch; do
    [[ -n "$snap_name" && -n "$snap_epoch" ]] || continue
    snap_base="${snap_name##*@}"
    [[ "$snap_base" == "$retained_basename" ]] && continue
    [[ "$snap_epoch" =~ ^[0-9]+$ ]] || continue
    (( snap_epoch < retained_epoch )) || continue
    if ! send_basename_matches_schedule "$snap_base" "$schedule_job_id"; then
      schedule_count=0
      if [[ "$snap_base" == "${SEND_SNAPSHOT_PREFIX}"* ]]; then
        for candidate_job_id in "${SCHEDULE_JOB_IDS[@]}"; do
          [[ "${SCHEDULE_SOURCE_ROOT[$candidate_job_id]:-}" == "$source_dataset" ]] || continue
          schedule_count=$((schedule_count + 1))
        done
        (( schedule_count == 1 )) || continue
      else
        continue
      fi
    fi
    old_basenames["$snap_base"]=1
  done < <(zfs list -H -p -t snapshot -o name,creation -d 1 "$source_dataset" 2>/dev/null || true)

  ((${#old_basenames[@]} > 0)) || return 0

  set_job_progress "cleanup" "95" "Cleaning source checkpoints."
  for snap_base in "${!old_basenames[@]}"; do
    while IFS=$'\t' read -r snap_name snap_epoch; do
      [[ -n "$snap_name" ]] || continue
      [[ "${snap_name##*@}" == "$snap_base" ]] || continue
      log "Deleting source send checkpoint: $snap_name"
      zfs destroy "$snap_name"
    done < <(zfs list -H -p -t snapshot -o name,creation -d 1 "$source_dataset" 2>/dev/null || true)
  done
}

purge_destination_for_reseed() {
  local destination="$1"

  is_valid_dataset_name "$destination" || return 1
  dataset_exists "$destination" || return 0

  log "Purging destination dataset for automatic reseed: ${destination}"
  zfs destroy -r "$destination"
}

run_child_jobs_have_failed() {
  local parent_run_id="$1"
  local file state action
  # shellcheck disable=SC2034
  local -A sibling_job=()

  while IFS= read -r file; do
    job_load "$file" sibling_job || continue
    [[ "$(job_get sibling_job JOB_TYPE)" == "send" ]] || continue
    [[ "$(job_get sibling_job JOB_MODE)" == "scheduled" ]] || continue
    [[ "$(job_get sibling_job PARENT_RUN_ID)" == "$parent_run_id" ]] || continue
    action="$(effective_job_action sibling_job)"
    [[ "$action" == "send_member" ]] || continue
    state="$(job_get sibling_job STATE)"
    if [[ "$state" == "failed" ]]; then
      return 0
    fi
  done < <(list_job_files)

  return 1
}

run_child_jobs_still_active() {
  local parent_run_id="$1"
  local file state action job_id
  # shellcheck disable=SC2034
  local -A sibling_job=()

  while IFS= read -r file; do
    job_load "$file" sibling_job || continue
    [[ "$(job_get sibling_job JOB_TYPE)" == "send" ]] || continue
    [[ "$(job_get sibling_job JOB_MODE)" == "scheduled" ]] || continue
    [[ "$(job_get sibling_job PARENT_RUN_ID)" == "$parent_run_id" ]] || continue
    job_id="$(job_get sibling_job JOB_ID)"
    [[ "$job_id" != "$CURRENT_JOB_ID" ]] || continue
    action="$(effective_job_action sibling_job)"
    [[ "$action" == "send_member" ]] || continue
    state="$(job_get sibling_job STATE)"
    if ! job_state_is_success "$state"; then
      return 0
    fi
  done < <(list_job_files)

  return 1
}

linked_job_state() {
  local wait_job_id="$1"
  local result_var="$2"
  local file
  # shellcheck disable=SC2034
  local -A linked_job=()

  printf -v "$result_var" ''
  [[ -n "$wait_job_id" ]] || return 1
  while IFS= read -r file; do
    job_load "$file" linked_job || continue
    if [[ "$(job_get linked_job JOB_ID)" == "$wait_job_id" ]]; then
      printf -v "$result_var" '%s' "$(job_get linked_job STATE)"
      return 0
    fi
  done < <(list_job_files)
  return 1
}

process_cleanup_member_job() {
  local wait_job_id wait_state destination_dataset snapshot_basename

  wait_job_id="$(job_get job WAIT_FOR_JOB_ID)"
  destination_dataset="$(job_get job DESTINATION_ROOT)"
  snapshot_basename="$(job_get job SOURCE_SNAPSHOT_NAME)"

  if linked_job_state "$wait_job_id" wait_state; then
    case "$wait_state" in
      queued|running|retry_wait)
        defer_current_job "Waiting for child send." 15
        return 2
        ;;
      failed)
        skip_job "Skipped; send failed."
        return 0
        ;;
    esac
  fi

  set_job_progress "cleanup" "92" "Queueing zero-change cleanup."
  queue_schedule_zero_change_cleanup_for_dataset "$(job_get job SCHEDULE_JOB_ID)" "$destination_dataset" "$snapshot_basename" || true
  complete_job "Queued zero-change cleanup."
  return 0
}

process_finalize_job() {
  local parent_run_id
  parent_run_id="$(job_get job PARENT_RUN_ID)"

  if run_child_jobs_have_failed "$parent_run_id"; then
    skip_job "Skipped; child failed."
    return 0
  fi

  if run_child_jobs_still_active "$parent_run_id"; then
    defer_current_job "Waiting for children." 15
    return 2
  fi

  complete_job "Scheduled window complete."
  return 0
}

process_pool_prep_job() {
  local dest_pool schedule_ids schedule_job_id dest_root capacity_dataset
  local retention_started retention_elapsed space_started space_elapsed
  # shellcheck disable=SC2034
  local -A planned_reclaim=()

  dest_pool="$(job_get job DESTINATION_POOL)"
  schedule_ids="$(job_get job SCHEDULE_JOB_IDS)"
  [[ -n "$dest_pool" && -n "$schedule_ids" ]] || {
    fail_current_job_final "Pool prep is missing settings."
    return 1
  }

  if ! acquire_pool_prep_lock "$dest_pool"; then
    defer_current_job "Waiting for pool prep lock." 15
    return 2
  fi
  CURRENT_PREP_POOL="$dest_pool"

  set_job_progress "preparing" "15" "Planning retention cleanup."
  retention_started="$(date +%s)"
  queue_pool_retention_cleanup "$dest_pool" "$dest_pool" planned_reclaim || true
  retention_elapsed=$(( $(date +%s) - retention_started ))
  log "Pool prep retention cleanup planning for ${dest_pool} completed in ${retention_elapsed}s"

  set_job_progress "preparing" "55" "Planning free-space cleanup."
  space_started="$(date +%s)"
  for schedule_job_id in $schedule_ids; do
    dest_root="${SCHEDULE_DEST_ROOT[$schedule_job_id]:-}"
    [[ -n "$dest_root" ]] || continue
    capacity_dataset="$(nearest_existing_dataset_ancestor "$dest_root")"
    [[ -n "$capacity_dataset" ]] || continue
    queue_pool_free_space_cleanup_for_schedule "$schedule_job_id" "$capacity_dataset" planned_reclaim || true
  done
  space_elapsed=$(( $(date +%s) - space_started ))
  log "Pool prep free-space cleanup planning for ${dest_pool} completed in ${space_elapsed}s"

  ensure_delete_worker_for_backlog
  release_current_prep_pool_lock
  complete_job "Pool prep done." 3600
  return 0
}

process_send_job() {
  local mode action member_count index
  clear_send_cleanup_caches
  mode="$(job_get job JOB_MODE)"
  action="$(effective_job_action job)"

  case "$mode:$action" in
    scheduled:finalize)
      process_finalize_job
      return $?
      ;;
  esac

  set_job_progress "preparing" "5" "Preparing."
  wait_for_unraid_array_to_be_actionable_for_current_job
  wait_for_autosnapshot_to_finish
  set_job_progress "preparing" "15" "Preparing."

  case "$mode:$action" in
    scheduled:pool_prep)
      process_pool_prep_job
      return $?
      ;;
    scheduled:prepare|scheduled:)
      if jobs_are_same_pool_overlap "$(job_get job SOURCE_ROOT)" "$(job_get job DESTINATION_ROOT)"; then
        fail_current_job_final "Source and destination overlap on the same pool. Choose a destination dataset outside the source tree."
        return 1
      fi
      if [[ "$(job_get job RESUME_ONLY 0)" == "1" ]]; then
        build_resume_members_for_current_job || {
          fail_current_job_final "Unable to rebuild the scheduled send resume state for this window. A fresh scheduled run will be needed."
          return 1
        }
        set_job_progress "snapshot_created" "28" "Queueing missing sends."
        queue_child_send_jobs || return 1
        job[COMPLETES_SCHEDULE_WINDOW]="0"
        complete_job "Queued missing sends."
        return 0
      fi
      prepare_scheduled_job_snapshot || return 1
      set_job_progress "snapshot_created" "28" "Queueing child sends."
      queue_child_send_jobs || return 1
      job[COMPLETES_SCHEDULE_WINDOW]="0"
      complete_job "Queued child sends."
      release_current_prep_pool_lock
      return 0
      ;;
    scheduled:send_member)
      if jobs_are_same_pool_overlap "$(job_get job SOURCE_ROOT)" "$(job_get job DESTINATION_ROOT)"; then
        fail_current_job_final "Source and destination overlap on the same pool. Choose a destination dataset outside the source tree."
        return 1
      fi
      register_active_send_datasets_for_current_job
      ;;
    manual_snapshot:*)
      if jobs_are_same_pool_overlap "$(job_get job DATASET)" "$(job_get job DESTINATION_ROOT)"; then
        fail_current_job_final "Source and destination overlap on the same pool. Choose a destination dataset outside the source tree."
        return 1
      fi
      register_active_send_datasets_for_current_job
      prepare_manual_snapshot_job || return 1
      ;;
    *)
      return 1
      ;;
  esac

  set_job_progress "snapshot_created" "30" "Snapshot ready."

  member_count="$(job_get job MEMBER_COUNT 0)"
  [[ "$member_count" =~ ^[0-9]+$ ]] || member_count=0
  (( member_count > 0 )) || return 1

  for ((index = 0; index < member_count; index++)); do
    send_member_snapshot "$index" "$member_count" || return $?
    if [[ "$mode:$action" == "scheduled:send_member" ]]; then
      cleanup_source_checkpoints_for_verified_member || return 1
      set_job_progress "cleanup" "$((90 + (index * 5 / (member_count == 0 ? 1 : member_count))))" "Queueing zero-change cleanup."
      queue_schedule_zero_change_cleanup_for_dataset "$(job_get job SCHEDULE_JOB_ID)" "$(job_get job MEMBER_${index}_DESTINATION)" "$(job_get job SOURCE_SNAPSHOT_NAME)" || true
    fi
  done

  if [[ "$mode:$action" == "scheduled:send_member" ]]; then
    complete_job "Send complete."
    return 0
  fi

  complete_job "Send complete."
  return 0
}

main() {
  local now_epoch candidate_path result=0 claim_selector="non_pool_prep"
  while (( $# > 0 )); do
    case "$1" in
      --pool-prep-only)
        WORKER_ROLE="pool_prep"
        claim_selector="pool_prep"
        ;;
    esac
    shift
  done

  ensure_runtime_layout || exit 1
  load_send_config
  load_schedule_state
  require_numeric_in_range "SEND_MAX_PARALLEL" "$SEND_MAX_PARALLEL" 1 8 || SEND_MAX_PARALLEL="$DEFAULT_SEND_MAX_PARALLEL"
  require_numeric_in_range "SEND_KEEP_ALL_FOR_DAYS" "$SEND_KEEP_ALL_FOR_DAYS" 1 36500 || SEND_KEEP_ALL_FOR_DAYS="$DEFAULT_SEND_KEEP_ALL_FOR_DAYS"
  require_numeric_in_range "SEND_KEEP_DAILY_UNTIL_DAYS" "$SEND_KEEP_DAILY_UNTIL_DAYS" 2 36500 || SEND_KEEP_DAILY_UNTIL_DAYS="$DEFAULT_SEND_KEEP_DAILY_UNTIL_DAYS"
  require_numeric_in_range "SEND_KEEP_WEEKLY_UNTIL_DAYS" "$SEND_KEEP_WEEKLY_UNTIL_DAYS" 3 36500 || SEND_KEEP_WEEKLY_UNTIL_DAYS="$DEFAULT_SEND_KEEP_WEEKLY_UNTIL_DAYS"
  if (( SEND_KEEP_ALL_FOR_DAYS >= SEND_KEEP_DAILY_UNTIL_DAYS || SEND_KEEP_DAILY_UNTIL_DAYS >= SEND_KEEP_WEEKLY_UNTIL_DAYS )); then
    SEND_KEEP_ALL_FOR_DAYS="$DEFAULT_SEND_KEEP_ALL_FOR_DAYS"
    SEND_KEEP_DAILY_UNTIL_DAYS="$DEFAULT_SEND_KEEP_DAILY_UNTIL_DAYS"
    SEND_KEEP_WEEKLY_UNTIL_DAYS="$DEFAULT_SEND_KEEP_WEEKLY_UNTIL_DAYS"
  fi
  parse_send_jobs_config

  trap cleanup EXIT INT TERM
  if [[ -n "${ZFSAS_WORKER_LOCK_DIR:-}" ]]; then
    case "${WORKER_ROLE}:${ZFSAS_WORKER_LOCK_DIR}" in
      send:"$SEND_WORKER_RUNTIME_DIR"/worker-*.lockdir|pool_prep:"$SEND_WORKER_RUNTIME_DIR"/pool-prep-*.lockdir)
        WORKER_LOCK_DIR="$ZFSAS_WORKER_LOCK_DIR"
        [[ -d "$WORKER_LOCK_DIR" ]] || mkdir "$WORKER_LOCK_DIR" 2>/dev/null || exit 0
        ;;
      *)
        exit 1
        ;;
    esac
  elif [[ "$WORKER_ROLE" == "pool_prep" ]]; then
    WORKER_LOCK_DIR="${SEND_WORKER_RUNTIME_DIR}/pool-prep-$$.lockdir"
    mkdir "$WORKER_LOCK_DIR" 2>/dev/null || exit 0
  else
    WORKER_LOCK_DIR="${SEND_WORKER_RUNTIME_DIR}/worker-$$.lockdir"
    mkdir "$WORKER_LOCK_DIR" 2>/dev/null || exit 0
  fi
  printf '%s\n' "$$" > "${WORKER_LOCK_DIR}/pid" 2>/dev/null || true

  exec >> "$LOG_FILE" 2>&1
  log "Send worker $$ starting (${WORKER_ROLE})"

  while :; do
    wait_for_unraid_array_to_be_actionable_for_send_queue
    now_epoch="$(date +%s)"
    candidate_path=""
    claim_next_send_job "$now_epoch" candidate_path "$claim_selector" || break
    [[ -n "$candidate_path" ]] || break

    # shellcheck disable=SC2034
    # shellcheck disable=SC2034
    declare -A job=()
    job_load "$candidate_path" job || break
    CURRENT_JOB_ID="$(job_get job JOB_ID)"
    CURRENT_JOB_PATH="$candidate_path"

    if ! acquire_job_claim "$CURRENT_JOB_ID"; then
      CURRENT_JOB_ID=""
      CURRENT_JOB_PATH=""
      continue
    fi

    job_load "$candidate_path" job || {
      release_job_claim "$CURRENT_JOB_ID"
      CURRENT_JOB_ID=""
      CURRENT_JOB_PATH=""
      continue
    }

    if ! job_is_retry_ready "$(job_get job STATE)" "$(job_get job RETRY_AT 0)" "$now_epoch"; then
      release_job_claim "$CURRENT_JOB_ID"
      CURRENT_JOB_ID=""
      CURRENT_JOB_PATH=""
      continue
    fi

    log "Processing send job $(job_get job JOB_ID) ($(job_get job JOB_MODE):$(effective_job_action job))"
    job[STATE]="running"
    # shellcheck disable=SC2034
    job[WORKER_PID]="$$"
    persist_job

    if process_send_job; then
      result=0
    else
      result="$?"
      if (( result != 2 )) && [[ "$(job_get job STATE)" == "running" ]]; then
        fail_current_job "Send failed during $(job_get job PHASE)."
      fi
    fi

    release_current_prep_pool_lock
    release_current_space_reservation
    clear_active_send_datasets
    release_job_claim "$CURRENT_JOB_ID"
    CURRENT_JOB_ID=""
    CURRENT_JOB_PATH=""
  done

  log "Send worker $$ finished (${WORKER_ROLE})"
}

main "$@"
