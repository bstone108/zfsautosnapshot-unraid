#!/bin/bash
set -Eeuo pipefail

KICKER="/usr/local/sbin/zfs_autosnapshot_queue_kicker"
LOG_FILE="/var/log/zfs_autosnapshot_send.log"

if [[ ! -x "$KICKER" ]]; then
  echo "Queue kicker is missing or not executable: $KICKER" >&2
  exit 1
fi

exec >> "$LOG_FILE" 2>&1

# shellcheck source=/dev/null
source /usr/local/emhttp/plugins/zfs.autosnapshot/scripts/ops-queue-lib.sh

zfsas_log_send_runtime_stamp "compat_send_wrapper"
log "Compatibility wrapper invoked for zfs_autosnapshot_send; forwarding to queue kicker."
exec "$KICKER" --manual-now "$@"
