#!/bin/bash
set -Eeuo pipefail
umask 077

CONFIG_DIR="/boot/config/plugins/zfs.autosnapshot"
CONFIG_FILE="${CONFIG_FILE:-$CONFIG_DIR/zfs_send.conf}"
RUNTIME_DIR="/var/run/zfs-autosnapshot-send"

SEND_SNAPSHOT_PREFIX="zfs-send-"
SEND_JOBS=""
KEEP_LOG_RUNS="${KEEP_LOG_RUNS:-2}"
LOCKFILE="${RUNTIME_DIR}/zfs_autosnapshot_send.lock"
LOCKDIR="${RUNTIME_DIR}/zfs_autosnapshot_send.lockdir"
ACTIVE_CHILD_PID_FILE="${RUNTIME_DIR}/zfs_autosnapshot_send.child.pid"
STOP_REQUEST_FILE="${RUNTIME_DIR}/zfs_autosnapshot_send.stop"
LOG_FILE="/var/log/zfs_autosnapshot_send.log"
SUMMARY_LOG_FILE="/var/log/zfs_autosnapshot_send.last.log"
LOG_RUN_MARKER="[SEND_RUN_START]"
DESTROY_HANG_TIMEOUT_SECONDS=120
POST_DELETE_RECHECK_WAIT_SECONDS="${POST_DELETE_RECHECK_WAIT_SECONDS:-3}"
POST_DELETE_RECHECK_INTERVAL_SECONDS="${POST_DELETE_RECHECK_INTERVAL_SECONDS:-2}"

RUN_STARTED_AT_EPOCH=0
RUN_STARTED_AT_HUMAN=""
RUN_SUMMARY_ENABLED=0
LOCK_FALLBACK_HELD=0
RUN_ERROR_CONTEXT=""
RUN_USER_ERROR=""
RUN_USER_ACTION=""
ACTIVE_CHILD_PID=""
STOP_REQUESTED=0

COUNT_JOBS_TOTAL=0
COUNT_JOBS_DUE=0
COUNT_JOBS_SENT=0
COUNT_JOBS_SKIPPED=0
COUNT_JOBS_FAILED=0
COUNT_DEST_SNAPSHOTS_PRUNED=0
COUNT_SOURCE_SNAPSHOTS_PRUNED=0
COUNT_DEST_SPACE_DELETES=0
COUNT_CREATED=0

JOB_IDS=()
declare -A JOB_SOURCE=()
declare -A JOB_DEST=()
declare -A JOB_FREQ=()
declare -A JOB_THRESHOLD=()
declare -A JOB_PREFIX=()
DESTINATION_PAIRS=()
declare -A DESTINATION_JOB_IDS=()
declare -A DESTINATION_JOB_GENERATION=()
declare -A DESTINATION_JOB_CANDIDATE_SNAP=()
declare -A DESTINATION_JOB_CANDIDATE_EPOCH=()
declare -A DESTINATION_JOB_CANDIDATE_GENERATION=()
declare -A DESTINATION_JOB_ANY_SNAPS=()

# shellcheck disable=SC2034  # Used indirectly by name in helper defaults.
declare -A NO_CONSTRAINT_RECLAIM=()

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

log() { echo "$@"; }

set_user_failure() {
  local what="$1"
  local action="$2"
  RUN_USER_ERROR="$what"
  RUN_USER_ACTION="$action"
}

die() {
  local message="$*"

  if [[ -z "$RUN_USER_ERROR" ]]; then
    RUN_USER_ERROR="$message"
  fi

  if [[ -z "$RUN_USER_ACTION" ]]; then
    RUN_USER_ACTION="Open the ZFS Send settings page, fix the reported problem, then run again."
  fi

  log "ERROR: $message" >&2
  exit 1
}

fail_config() {
  local message="$1"
  local action="$2"
  set_user_failure "$message" "$action"
  die "$message"
}

# shellcheck disable=SC2329  # Invoked via trap ERR.
record_error_context() {
  local line="$1"
  local cmd="$2"
  RUN_ERROR_CONTEXT="line ${line}: ${cmd}"

  if [[ -z "$RUN_USER_ERROR" ]]; then
    RUN_USER_ERROR="The ZFS send run stopped unexpectedly because an internal command failed."
  fi

  if [[ -z "$RUN_USER_ACTION" ]]; then
    RUN_USER_ACTION="Open the ZFS Send debug log, review the reported command problem, then run again."
  fi
}

parse_config_value() {
  local raw="$1"
  local value

  value="$(trim "$raw")"
  [[ -n "$value" ]] || {
    printf ''
    return 0
  }

  if [[ "$value" == \"*\" && "$value" == *\" && ${#value} -ge 2 ]]; then
    value="${value:1:${#value}-2}"
    value="${value//\\\\/\\}"
    value="${value//\\\"/\"}"
    printf '%s' "$value"
    return 0
  fi

  if [[ "$value" == \'*\' && "$value" == *\' && ${#value} -ge 2 ]]; then
    value="${value:1:${#value}-2}"
    printf '%s' "$value"
    return 0
  fi

  value="${value%%#*}"
  value="$(trim "$value")"
  printf '%s' "$value"
}

apply_config_key() {
  local key="$1"
  local value="$2"

  case "$key" in
    SEND_SNAPSHOT_PREFIX|SEND_JOBS|KEEP_LOG_RUNS)
      if [[ "$value" == *$'\n'* || "$value" == *$'\r'* ]]; then
        return 0
      fi
      printf -v "$key" '%s' "$value"
      ;;
  esac
}

load_config_file() {
  local path="$1"
  local line key raw value

  [[ -f "$path" ]] || return 0

  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ "$line" =~ ^[[:space:]]*$ ]] && continue

    if [[ "$line" =~ ^[[:space:]]*([A-Z0-9_]+)[[:space:]]*=(.*)$ ]]; then
      key="${BASH_REMATCH[1]}"
      raw="${BASH_REMATCH[2]}"
      value="$(parse_config_value "$raw")"
      apply_config_key "$key" "$value"
    fi
  done <"$path"
}

require_numeric_in_range() {
  local name="$1"
  local value="$2"
  local min="$3"
  local max="$4"

  [[ "$value" =~ ^[0-9]+$ ]] || fail_config "${name} must be an integer." "Set ${name} to a whole number between ${min} and ${max}."

  if ((value < min || value > max)); then
    fail_config "${name} is out of range (${value})." "Set ${name} between ${min} and ${max}."
  fi
}

ensure_existing_directory() {
  local path="$1"
  local label="$2"

  [[ -n "$path" ]] || fail_config "${label} path is empty." "Reset ${label} to its default location and run again."
  [[ ! -L "$path" ]] || fail_config "${label} path '$path' is a symlink, which is unsafe." "Remove the symlink and restore a normal directory."
  [[ -d "$path" ]] || fail_config "${label} path '$path' is missing." "Create the directory or restore the default path."
}

ensure_secure_directory() {
  local path="$1"
  local mode="$2"
  local label="$3"

  [[ -n "$path" ]] || fail_config "${label} path is empty." "Reset ${label} to its default location and run again."
  [[ ! -L "$path" ]] || fail_config "${label} path '$path' is a symlink, which is unsafe." "Remove the symlink and restore a normal directory."

  if [[ -e "$path" && ! -d "$path" ]]; then
    fail_config "${label} path '$path' is not a directory." "Remove the unexpected file and try again."
  fi

  if [[ ! -e "$path" ]]; then
    mkdir -p "$path" || fail_config "Unable to create ${label} directory '$path'." "Verify the boot/config filesystem is writable, then run again."
  fi

  chmod "$mode" "$path" >/dev/null 2>&1 || true
}

ensure_secure_file() {
  local path="$1"
  local mode="$2"
  local label="$3"
  local parent

  [[ -n "$path" ]] || fail_config "${label} path is empty." "Reset ${label} to its default location and run again."
  [[ ! -L "$path" ]] || fail_config "${label} path '$path' is a symlink, which is unsafe." "Remove the symlink and restore a normal file."

  parent="$(dirname "$path")"
  ensure_existing_directory "$parent" "${label} parent directory"

  if [[ -e "$path" && ! -f "$path" ]]; then
    fail_config "${label} path '$path' is not a regular file." "Remove the unexpected file and try again."
  fi

  if [[ ! -e "$path" ]]; then
    : >"$path" || fail_config "Unable to create ${label} file '$path'." "Verify the destination is writable, then run again."
  fi

  chmod "$mode" "$path" >/dev/null 2>&1 || true
}

prepare_runtime_state() {
  ensure_secure_directory "$RUNTIME_DIR" 0700 "Runtime directory"
  ensure_secure_file "$LOCKFILE" 0600 "Lock file"
  ensure_existing_directory "$(dirname "$LOG_FILE")" "Debug log directory"
  ensure_existing_directory "$(dirname "$SUMMARY_LOG_FILE")" "Summary log directory"
  ensure_secure_file "$LOG_FILE" 0600 "Debug log"
  ensure_secure_file "$SUMMARY_LOG_FILE" 0600 "Summary log"
}

clear_active_child_state() {
  ACTIVE_CHILD_PID=""
  rm -f "$ACTIVE_CHILD_PID_FILE" >/dev/null 2>&1 || true
}

remember_active_child_pid() {
  local pid="$1"

  ACTIVE_CHILD_PID="$pid"
  printf '%s\n' "$pid" >"$ACTIVE_CHILD_PID_FILE"
  chmod 0600 "$ACTIVE_CHILD_PID_FILE" >/dev/null 2>&1 || true
}

# shellcheck disable=SC2329  # Invoked via trap TERM/INT.
handle_stop_signal() {
  local signal_name="$1"
  STOP_REQUESTED=1
  log "Received ${signal_name}; stopping after the current command finishes."
  : >"$STOP_REQUEST_FILE" 2>/dev/null || true

  if [[ -n "$ACTIVE_CHILD_PID" ]] && kill -0 "$ACTIVE_CHILD_PID" >/dev/null 2>&1; then
    kill "$ACTIVE_CHILD_PID" >/dev/null 2>&1 || true
  fi
}

abort_if_stop_requested() {
  if ((STOP_REQUESTED)) || [[ -f "$STOP_REQUEST_FILE" ]]; then
    STOP_REQUESTED=1
    die "Run stopped because a stop request was received."
  fi
}

# shellcheck disable=SC2329  # Reached via EXIT trap through on_exit().
write_run_summary() {
  local exit_code="$1"
  local tmp_file status_line elapsed

  tmp_file="$(mktemp "${SUMMARY_LOG_FILE}.tmp.XXXXXX")" || return 0
  elapsed=$(( $(date +%s) - RUN_STARTED_AT_EPOCH ))

  if (( exit_code == 0 )); then
    status_line="Result: Success"
  else
    status_line="Result: Failed"
  fi

  {
    echo "ZFS Send Run Summary"
    echo "Started: ${RUN_STARTED_AT_HUMAN}"
    echo "Finished: $(date +'%Y-%m-%d %H:%M:%S %Z')"
    echo "Elapsed seconds: ${elapsed}"
    echo "$status_line"
    echo "Jobs configured: ${COUNT_JOBS_TOTAL}"
    echo "Jobs due: ${COUNT_JOBS_DUE}"
    echo "Jobs replicated successfully: ${COUNT_JOBS_SENT}"
    echo "Jobs skipped (not due or blocked): ${COUNT_JOBS_SKIPPED}"
    echo "Jobs failed: ${COUNT_JOBS_FAILED}"
    echo "Snapshots created: ${COUNT_CREATED}"
    echo "Older source send snapshots pruned: ${COUNT_SOURCE_SNAPSHOTS_PRUNED}"
    echo "Older destination send snapshots pruned: ${COUNT_DEST_SNAPSHOTS_PRUNED}"
    echo "Destination low-space deletions: ${COUNT_DEST_SPACE_DELETES}"
    if [[ -n "$RUN_ERROR_CONTEXT" ]]; then
      echo "Error context: ${RUN_ERROR_CONTEXT}"
    fi
    if [[ -n "$RUN_USER_ERROR" ]]; then
      echo "User-facing error: ${RUN_USER_ERROR}"
    fi
    if [[ -n "$RUN_USER_ACTION" ]]; then
      echo "Suggested action: ${RUN_USER_ACTION}"
    fi
  } >"$tmp_file"

  if mv -f "$tmp_file" "$SUMMARY_LOG_FILE" 2>/dev/null; then
    chmod 0600 "$SUMMARY_LOG_FILE" >/dev/null 2>&1 || true
    chown root:root "$SUMMARY_LOG_FILE" >/dev/null 2>&1 || true
  else
    rm -f "$tmp_file" >/dev/null 2>&1 || true
  fi
}

# shellcheck disable=SC2329  # Invoked via trap EXIT.
on_exit() {
  local exit_code="$?"
  set +e
  clear_active_child_state

  if (( LOCK_FALLBACK_HELD )); then
    rmdir "$LOCKDIR" >/dev/null 2>&1 || true
  fi

  if (( RUN_SUMMARY_ENABLED )); then
    write_run_summary "$exit_code" || true
  fi
}

acquire_lock() {
  if command -v flock >/dev/null 2>&1; then
    exec 200>"$LOCKFILE"
    if ! flock -n 200; then
      log "Another instance is already running (lock: $LOCKFILE). Exiting."
      exit 0
    fi
    echo "$$" 1>&200
  else
    if ! mkdir "$LOCKDIR" 2>/dev/null; then
      log "Another instance is already running (lock: $LOCKDIR). Exiting."
      exit 0
    fi
    echo "$$" >"$LOCKDIR/pid"
    LOCK_FALLBACK_HELD=1
  fi

  rm -f "$STOP_REQUEST_FILE" "$ACTIVE_CHILD_PID_FILE" >/dev/null 2>&1 || true
}

run_command_with_child_tracking() {
  local description="$1"
  local timeout_seconds="$2"
  shift 2
  local child_pid waited=0

  abort_if_stop_requested

  "$@" &
  child_pid=$!
  remember_active_child_pid "$child_pid" "$description"

  while kill -0 "$child_pid" >/dev/null 2>&1; do
    abort_if_stop_requested
    sleep 1
    waited=$((waited + 1))
    if (( timeout_seconds > 0 && waited >= timeout_seconds )); then
      kill "$child_pid" >/dev/null 2>&1 || true
      wait "$child_pid" >/dev/null 2>&1 || true
      clear_active_child_state
      set_user_failure \
        "${description} timed out and was stopped." \
        "Check pool health and command responsiveness, then run again."
      die "${description} timed out after ${timeout_seconds}s."
    fi
  done

  wait "$child_pid"
  clear_active_child_state
}

run_pipeline_command() {
  local description="$1"
  local timeout_seconds="$2"
  local command_string="$3"

  run_command_with_child_tracking "$description" "$timeout_seconds" bash -o pipefail -c "$command_string"
}

threshold_to_bytes() {
  local raw="$1"
  local upper num unit

  upper="$(echo "$raw" | tr '[:lower:]' '[:upper:]')"
  upper="${upper%B}"
  num="${upper%%[!0-9]*}"
  unit="${upper#"$num"}"

  if [[ -z "$num" || ! "$num" =~ ^[0-9]+$ ]]; then
    fail_config "Bad threshold '$raw'." "Use thresholds like 500M, 100G, or 2T."
  fi

  case "$unit" in
    K) echo $((num * 1024)) ;;
    M) echo $((num * 1024 * 1024)) ;;
    G) echo $((num * 1024 * 1024 * 1024)) ;;
    T) echo $((num * 1024 * 1024 * 1024 * 1024)) ;;
    *) fail_config "Bad unit in '$raw'." "Use K, M, G, or T (optional trailing B)." ;;
  esac
}

get_pool_avail() {
  local value
  value="$(zfs list -o avail -H -p "$1" 2>/dev/null || true)"
  [[ "$value" =~ ^[0-9]+$ ]] && echo "$value" || echo ""
}

get_pool_freeing() {
  local value
  value="$(zpool get -H -o value freeing "$1" 2>/dev/null || true)"
  [[ "$value" =~ ^[0-9]+$ ]] && echo "$value" || echo 0
}

get_pool_effective_avail() {
  local pool="$1"
  local avail freeing
  avail="$(get_pool_avail "$pool")"
  [[ -n "$avail" ]] || {
    echo ""
    return 1
  }
  freeing="$(get_pool_freeing "$pool")"
  echo $((avail + freeing))
}

get_dataset_numeric_property() {
  local dataset="$1"
  local property="$2"
  local value
  value="$(zfs get -H -p -o value "$property" "$dataset" 2>/dev/null || true)"
  [[ "$value" =~ ^[0-9]+$ ]] && echo "$value" || echo 0
}

get_dataset_quota_headroom() {
  local dataset="$1"
  local quota used

  quota="$(get_dataset_numeric_property "$dataset" "quota")"
  (( quota > 0 )) || {
    echo ""
    return 1
  }

  used="$(get_dataset_numeric_property "$dataset" "used")"
  if (( used >= quota )); then
    echo 0
  else
    echo $((quota - used))
  fi
}

get_dataset_refquota_headroom() {
  local dataset="$1"
  local refquota referenced

  refquota="$(get_dataset_numeric_property "$dataset" "refquota")"
  (( refquota > 0 )) || {
    echo ""
    return 1
  }

  referenced="$(get_dataset_numeric_property "$dataset" "referenced")"
  if (( referenced >= refquota )); then
    echo 0
  else
    echo $((refquota - referenced))
  fi
}

emit_dataset_capacity_constraints() {
  local dataset="$1"
  local pool="${dataset%%/*}"
  local current pool_effective quota_headroom refquota_headroom

  pool_effective="$(get_pool_effective_avail "$pool")"
  if [[ -n "$pool_effective" ]]; then
    printf 'pool:%s\t%s\n' "$pool" "$pool_effective"
  fi

  current="$dataset"
  while :; do
    quota_headroom="$(get_dataset_quota_headroom "$current" || true)"
    if [[ -n "$quota_headroom" ]]; then
      printf 'quota:%s\t%s\n' "$current" "$quota_headroom"
    fi

    [[ "$current" == "$pool" ]] && break
    current="${current%/*}"
  done

  refquota_headroom="$(get_dataset_refquota_headroom "$dataset" || true)"
  if [[ -n "$refquota_headroom" ]]; then
    printf 'refquota:%s\t%s\n' "$dataset" "$refquota_headroom"
  fi
}

get_dataset_active_constraints() {
  local dataset="$1"
  local delta_map_name="$2"
  local effective_var_name="$3"
  local active_constraints_var_name="$4"
  local token base adjusted best_value=""
  local -n delta_ref="$delta_map_name"
  local -n active_constraints_ref="$active_constraints_var_name"

  active_constraints_ref=()

  while IFS=$'\t' read -r token base; do
    [[ -n "$token" && "$base" =~ ^[0-9]+$ ]] || continue
    adjusted=$((base + ${delta_ref[$token]:-0}))
    (( adjusted >= 0 )) || adjusted=0

    if [[ -z "$best_value" ]] || (( adjusted < best_value )); then
      best_value="$adjusted"
      active_constraints_ref=("$token")
    elif (( adjusted == best_value )); then
      active_constraints_ref+=("$token")
    fi
  done < <(emit_dataset_capacity_constraints "$dataset")

  if [[ -z "$best_value" ]]; then
    printf -v "$effective_var_name" ''
    return 1
  fi

  printf -v "$effective_var_name" '%s' "$best_value"
  return 0
}

get_dataset_effective_avail() {
  local dataset="$1"
  local delta_map_name="${2:-NO_CONSTRAINT_RECLAIM}"
  local effective_avail
  local -a active_constraints=()

  get_dataset_active_constraints "$dataset" "$delta_map_name" effective_avail active_constraints || {
    echo ""
    return 1
  }

	echo "$effective_avail"
}

nearest_existing_dataset_ancestor() {
	local dataset="$1"
	local current="$dataset"

	while [[ -n "$current" ]]; do
		if zfs list -H -o name "$current" >/dev/null 2>&1; then
			echo "$current"
			return 0
		fi

		if [[ "$current" != */* ]]; then
			break
		fi
		current="${current%/*}"
	done

	echo ""
	return 1
}

constraints_are_pool_only() {
  local constraints_var_name="$1"
  local constraint
  local -n constraints_ref="$constraints_var_name"

  (( ${#constraints_ref[@]} > 0 )) || return 1
  for constraint in "${constraints_ref[@]}"; do
    [[ "$constraint" == pool:* ]] || return 1
  done

  return 0
}

should_wait_for_post_delete_recheck() {
  local dataset="$1"
  local constraints_var_name="$2"
  local after_effective_avail="$3"
  local before_effective_avail="$4"
  local pool freeing

  if (( POST_DELETE_RECHECK_WAIT_SECONDS <= 0 )); then
    return 1
  fi

  constraints_are_pool_only "$constraints_var_name" || return 0

  pool="${dataset%%/*}"
  freeing="$(get_pool_freeing "$pool")"

  if [[ "$freeing" =~ ^[0-9]+$ ]]; then
    if (( freeing > 0 )); then
      return 1
    fi

    if (( after_effective_avail != before_effective_avail )); then
      return 1
    fi
  fi

  return 0
}

dataset_is_within_scope() {
  local dataset="$1"
  local scope="$2"
  [[ "$dataset" == "$scope" || "$dataset" == "$scope/"* ]]
}

candidate_affects_constraint() {
  local dataset="$1"
  local constraint="$2"
  local scope

  case "$constraint" in
    pool:*)
      [[ "${dataset%%/*}" == "${constraint#pool:}" ]]
      return
      ;;
    quota:*)
      scope="${constraint#quota:}"
      dataset_is_within_scope "$dataset" "$scope"
      return
      ;;
    refquota:*)
      return 1
      ;;
  esac

  return 1
}

candidate_affects_any_constraint() {
  local dataset="$1"
  local constraints_var_name="$2"
  local constraint
  local -n constraints_ref="$constraints_var_name"

  for constraint in "${constraints_ref[@]}"; do
    if candidate_affects_constraint "$dataset" "$constraint"; then
      return 0
    fi
  done

  return 1
}

format_constraint_list() {
  local constraints_var_name="$1"
  local -n constraints_ref="$constraints_var_name"
  local constraint joined=""

  for constraint in "${constraints_ref[@]}"; do
    if [[ -n "$joined" ]]; then
      joined+=", "
    fi
    joined+="$constraint"
  done

  printf '%s\n' "$joined"
}

snapshot_basename() {
  local snap="$1"
  printf '%s' "${snap##*@}"
}

job_frequency_seconds() {
  case "$1" in
    15m) echo 900 ;;
    30m) echo 1800 ;;
    1h) echo 3600 ;;
    6h) echo 21600 ;;
    12h) echo 43200 ;;
    1d) echo 86400 ;;
    7d) echo 604800 ;;
    *) echo 0 ;;
  esac
}

parse_send_jobs() {
  local raw_jobs pair job_id source dest freq thresh prefix threshold_bytes
  local -A seen_job_ids=()

  IFS=';' read -r -a raw_jobs <<<"$SEND_JOBS"
  for pair in "${raw_jobs[@]}"; do
    pair="$(trim "$pair")"
    [[ -n "$pair" ]] || continue

    IFS='|' read -r job_id source dest freq thresh <<<"$pair"
    job_id="$(trim "$job_id")"
    source="$(trim "$source")"
    dest="$(trim "$dest")"
    freq="$(trim "$freq")"
    thresh="$(trim "$thresh")"

    [[ "$job_id" =~ ^[a-f0-9]{12}$ ]] || fail_config "Invalid ZFS send job id '${job_id}'." "Re-save the ZFS send jobs from the settings page."
    [[ -n "$source" && -n "$dest" && -n "$freq" && -n "$thresh" ]] || fail_config "Incomplete ZFS send job '${pair}'." "Each send job needs a source dataset, destination dataset, frequency, and target."
    [[ "$source" =~ ^[A-Za-z0-9._/:+-]+$ ]] || fail_config "Invalid ZFS send source dataset '${source}'." "Use a standard ZFS dataset path for the source."
    [[ "$dest" =~ ^[A-Za-z0-9._/:+-]+$ ]] || fail_config "Invalid ZFS send destination dataset '${dest}'." "Use a standard ZFS dataset path for the destination."
    [[ "$source" != "$dest" ]] || fail_config "Source and destination match for '${source}'." "Choose a different destination dataset for each send job."
    [[ "$dest" == */* ]] || fail_config "Destination '${dest}' must include a dataset name below a pool." "Use a destination like pool/replicas/name instead of a pool root."

    case "$freq" in
      15m|30m|1h|6h|12h|1d|7d) ;;
      *) fail_config "Invalid frequency '${freq}' for ZFS send job '${source}' -> '${dest}'." "Use one of: 15m, 30m, 1h, 6h, 12h, 1d, 7d." ;;
    esac

    threshold_bytes="$(threshold_to_bytes "$thresh")"
    prefix="${SEND_SNAPSHOT_PREFIX}${job_id}-"

    if [[ -n "${seen_job_ids[$job_id]:-}" ]]; then
      fail_config "Duplicate ZFS send job id '${job_id}' detected." "Re-save the send jobs so each source/destination pair is unique."
    fi

    seen_job_ids[$job_id]=1
    JOB_IDS+=("$job_id")
    JOB_SOURCE["$job_id"]="$source"
    JOB_DEST["$job_id"]="$dest"
    JOB_FREQ["$job_id"]="$freq"
    JOB_THRESHOLD["$job_id"]="$threshold_bytes"
    JOB_PREFIX["$job_id"]="$prefix"
    DESTINATION_PAIRS+=("${dest}:${threshold_bytes}")
    DESTINATION_JOB_IDS["$dest"]+=" ${job_id}"
  done
}

list_job_snapshots() {
  local dataset="$1"
  local prefix="$2"
  local inventory

  inventory="$(zfs list -H -p -t snapshot -o name,creation -d 1 "$dataset" 2>/dev/null | grep -F "@${prefix}" | sort -t $'\t' -k2,2n || true)"
  printf '%s' "$inventory"
}

find_latest_common_snapshot() {
  local job_id="$1"
  local source="$2"
  local dest="$3"
  local prefix="$4"
  local result_name_var="$5"
  local result_epoch_var="$6"
  local source_inventory dest_inventory snap_name snap_epoch snap_base
  local -A dest_basenames=()

  printf -v "$result_name_var" ''
  printf -v "$result_epoch_var" ''

  source_inventory="$(list_job_snapshots "$source" "$prefix")"
  dest_inventory="$(list_job_snapshots "$dest" "$prefix")"

  while IFS=$'\t' read -r snap_name snap_epoch; do
    [[ -n "$snap_name" && -n "$snap_epoch" ]] || continue
    dest_basenames["$(snapshot_basename "$snap_name")"]="$snap_epoch"
  done <<<"$dest_inventory"

  while IFS=$'\t' read -r snap_name snap_epoch; do
    [[ -n "$snap_name" && -n "$snap_epoch" ]] || continue
    snap_base="$(snapshot_basename "$snap_name")"
    if [[ -n "${dest_basenames[$snap_base]:-}" ]]; then
      printf -v "$result_name_var" '%s' "$snap_base"
      printf -v "$result_epoch_var" '%s' "$snap_epoch"
    fi
  done <<<"$source_inventory"
}

job_is_due() {
  local frequency="$1"
  local last_success_epoch="$2"
  local interval

  interval="$(job_frequency_seconds "$frequency")"
  (( interval > 0 )) || return 0
  [[ -n "$last_success_epoch" ]] || return 0

  (( NOW_EPOCH - last_success_epoch >= interval ))
}

ensure_destination_parent_exists() {
  local dest="$1"
  local parent="${dest%/*}"
  local pool="${dest%%/*}"

  zfs list -H -o name "$pool" >/dev/null 2>&1 || fail_config "Destination pool '$pool' does not exist." "Create the destination pool before running ZFS send."

  if [[ "$parent" != "$pool" ]]; then
    if ! zfs list -H -o name "$parent" >/dev/null 2>&1; then
      log "Creating destination parent dataset: $parent"
      if ! zfs create -p "$parent"; then
        set_user_failure \
          "Could not create destination parent dataset '$parent'." \
          "Check destination pool health and permissions, then run again."
        die "zfs create -p failed for '$parent'."
      fi
    fi
  fi
}

mark_destination_candidates_dirty_for_dataset() {
  local dataset="$1"
  local job_id

  for job_id in ${DESTINATION_JOB_IDS["$dataset"]:-}; do
    DESTINATION_JOB_GENERATION["$job_id"]=$(( ${DESTINATION_JOB_GENERATION["$job_id"]:-0} + 1 ))
  done
}

load_oldest_deletable_destination_snapshot_for_job() {
  local job_id="$1"
  local dataset="${JOB_DEST[$job_id]}"
  local prefix="${JOB_PREFIX[$job_id]}"
  local generation="${DESTINATION_JOB_GENERATION[$job_id]:-0}"
  local refreshed="${DESTINATION_JOB_CANDIDATE_GENERATION[$job_id]:--1}"
  local inventory snap_name snap_epoch newest_snap="" oldest_deletable_snap="" oldest_deletable_epoch=""

  if [[ "$generation" == "$refreshed" ]]; then
    return 0
  fi

  DESTINATION_JOB_CANDIDATE_SNAP["$job_id"]=""
  DESTINATION_JOB_CANDIDATE_EPOCH["$job_id"]=""
  DESTINATION_JOB_ANY_SNAPS["$job_id"]=0

  inventory="$(list_job_snapshots "$dataset" "$prefix")"
  while IFS=$'\t' read -r snap_name snap_epoch; do
    [[ -n "$snap_name" && -n "$snap_epoch" ]] || continue
    DESTINATION_JOB_ANY_SNAPS["$job_id"]=1
    newest_snap="$snap_name"
    if [[ -z "$oldest_deletable_snap" ]]; then
      oldest_deletable_snap="$snap_name"
      oldest_deletable_epoch="$snap_epoch"
    fi
  done <<<"$inventory"

  if [[ -n "$oldest_deletable_snap" && "$oldest_deletable_snap" != "$newest_snap" ]]; then
    DESTINATION_JOB_CANDIDATE_SNAP["$job_id"]="$oldest_deletable_snap"
    DESTINATION_JOB_CANDIDATE_EPOCH["$job_id"]="$oldest_deletable_epoch"
  fi

  DESTINATION_JOB_CANDIDATE_GENERATION["$job_id"]="$generation"
}

find_oldest_destination_snapshot_for_constraints() {
  local constraints_var_name="$1"
  local result_snap_var_name="$2"
  local result_dataset_var_name="$3"
  local result_any_var_name="$4"
  local job_id dataset snap epoch selected_snap="" selected_epoch="" selected_dataset="" found_any=0
  local -n constraints_ref="$constraints_var_name"

  for job_id in "${JOB_IDS[@]}"; do
    dataset="${JOB_DEST[$job_id]}"
    if ! candidate_affects_any_constraint "$dataset" "$constraints_var_name"; then
      continue
    fi

    load_oldest_deletable_destination_snapshot_for_job "$job_id"
    if (( ${DESTINATION_JOB_ANY_SNAPS["$job_id"]:-0} > 0 )); then
      found_any=1
    fi

    snap="${DESTINATION_JOB_CANDIDATE_SNAP[$job_id]:-}"
    epoch="${DESTINATION_JOB_CANDIDATE_EPOCH[$job_id]:-}"
    [[ -n "$snap" && -n "$epoch" ]] || continue

    if [[ -z "$selected_epoch" ]] || (( epoch < selected_epoch )); then
      selected_snap="$snap"
      selected_epoch="$epoch"
      selected_dataset="$dataset"
    fi
  done

  printf -v "$result_snap_var_name" '%s' "$selected_snap"
  printf -v "$result_dataset_var_name" '%s' "$selected_dataset"
  printf -v "$result_any_var_name" '%s' "$found_any"
}

do_destroy_snapshot() {
  local snap="$1"
  local kind="$2"

  abort_if_stop_requested
  log "  Destroying snapshot (${kind}): $snap"

  run_command_with_child_tracking "zfs destroy ${snap}" "$DESTROY_HANG_TIMEOUT_SECONDS" zfs destroy "$snap"

  if [[ "$kind" == "destination_low_space" ]]; then
    COUNT_DEST_SPACE_DELETES=$((COUNT_DEST_SPACE_DELETES + 1))
    COUNT_DEST_SNAPSHOTS_PRUNED=$((COUNT_DEST_SNAPSHOTS_PRUNED + 1))
  elif [[ "$kind" == "source_cleanup" ]]; then
    COUNT_SOURCE_SNAPSHOTS_PRUNED=$((COUNT_SOURCE_SNAPSHOTS_PRUNED + 1))
  elif [[ "$kind" == "destination_cleanup" ]]; then
    COUNT_DEST_SNAPSHOTS_PRUNED=$((COUNT_DEST_SNAPSHOTS_PRUNED + 1))
  fi
}

ensure_destination_space_for_job() {
  local job_id="$1"
  local dest_dataset="${JOB_DEST[$job_id]}"
  local threshold="${JOB_THRESHOLD[$job_id]}"
  local effective_avail low_constraints_display="" oldest_snap="" oldest_dataset="" any_candidates=0 after_effective_avail waited capacity_dataset
  # shellcheck disable=SC2034  # Filled indirectly through nameref output.
  local -a active_constraints=()

  capacity_dataset="$(nearest_existing_dataset_ancestor "$dest_dataset")"
  if [[ -z "$capacity_dataset" ]]; then
    log "Destination $dest_dataset check failed: unable to find an existing ancestor dataset for capacity checks."
    return 1
  fi

  while :; do
    abort_if_stop_requested
    if ! get_dataset_active_constraints "$capacity_dataset" NO_CONSTRAINT_RECLAIM effective_avail active_constraints; then
      log "Destination $dest_dataset check failed: unable to read available space from capacity anchor ${capacity_dataset}."
      return 1
    fi

    if (( effective_avail >= threshold )); then
      return 0
    fi

    low_constraints_display="$(format_constraint_list active_constraints)"
    log "Destination $dest_dataset is below its free-space target: effective_avail=${effective_avail} min_required=${threshold} active_constraints=${low_constraints_display}"

    find_oldest_destination_snapshot_for_constraints active_constraints oldest_snap oldest_dataset any_candidates

    if (( any_candidates == 0 )) || [[ -z "$oldest_snap" ]]; then
      log "Destination $dest_dataset is low on space, but no older ZFS send snapshots remain that can benefit it."
      return 1
    fi

    log "Destination $dest_dataset low on space -> deleting oldest eligible send snapshot: $oldest_snap"
    do_destroy_snapshot "$oldest_snap" "destination_low_space"
    mark_destination_candidates_dirty_for_dataset "$oldest_dataset"

    after_effective_avail="$(get_dataset_effective_avail "$capacity_dataset")"
    if [[ -z "$after_effective_avail" ]]; then
      log "Destination $dest_dataset low on space -> unable to re-check available space from capacity anchor ${capacity_dataset} after deleting $oldest_snap."
      return 1
    fi

    if (( after_effective_avail <= effective_avail )) && should_wait_for_post_delete_recheck "$capacity_dataset" active_constraints "$after_effective_avail" "$effective_avail"; then
      log "Destination $dest_dataset low on space -> waiting up to ${POST_DELETE_RECHECK_WAIT_SECONDS}s for free-space accounting to update after deleting $oldest_snap."
      waited=0
      while (( waited < POST_DELETE_RECHECK_WAIT_SECONDS )); do
        abort_if_stop_requested
        sleep "$POST_DELETE_RECHECK_INTERVAL_SECONDS"
        waited=$((waited + POST_DELETE_RECHECK_INTERVAL_SECONDS))
        after_effective_avail="$(get_dataset_effective_avail "$capacity_dataset")"
        [[ -n "$after_effective_avail" ]] || break
        if (( after_effective_avail > effective_avail )); then
          break
        fi
      done
    fi
  done
}

cleanup_job_snapshots_keep_newest() {
  local dataset="$1"
  local prefix="$2"
  local keep_basename="$3"
  local cleanup_kind="$4"
  local inventory snap_name snap_base

  inventory="$(list_job_snapshots "$dataset" "$prefix")"
  while IFS=$'\t' read -r snap_name _; do
    [[ -n "$snap_name" ]] || continue
    snap_base="$(snapshot_basename "$snap_name")"
    if [[ "$snap_base" == "$keep_basename" ]]; then
      continue
    fi
    do_destroy_snapshot "$snap_name" "$cleanup_kind"
  done <<<"$inventory"

  mark_destination_candidates_dirty_for_dataset "$dataset"
}

run_send_job() {
  local job_id="$1"
  local source="${JOB_SOURCE[$job_id]}"
  local dest="${JOB_DEST[$job_id]}"
  local prefix="${JOB_PREFIX[$job_id]}"
  local frequency="${JOB_FREQ[$job_id]}"
  local latest_common_name="" latest_common_epoch="" current_timestamp new_basename new_snapshot cmd description

  COUNT_JOBS_TOTAL=$((COUNT_JOBS_TOTAL + 1))

  zfs list -H -o name "$source" >/dev/null 2>&1 || {
    COUNT_JOBS_FAILED=$((COUNT_JOBS_FAILED + 1))
    log "Job ${job_id}: source dataset '$source' does not exist."
    return 1
  }

  ensure_destination_parent_exists "$dest"
  find_latest_common_snapshot "$job_id" "$source" "$dest" "$prefix" latest_common_name latest_common_epoch

  if ! job_is_due "$frequency" "$latest_common_epoch"; then
    COUNT_JOBS_SKIPPED=$((COUNT_JOBS_SKIPPED + 1))
    log "Job ${job_id}: skipping ${source} -> ${dest}; interval ${frequency} has not elapsed yet."
    return 0
  fi

  COUNT_JOBS_DUE=$((COUNT_JOBS_DUE + 1))

  if ! ensure_destination_space_for_job "$job_id"; then
    COUNT_JOBS_SKIPPED=$((COUNT_JOBS_SKIPPED + 1))
    log "Job ${job_id}: destination '${dest}' is still below its free-space target after cleanup; skipping send for now."
    return 0
  fi

  current_timestamp="$(date +%Y-%m-%d_%H-%M-%S)"
  new_basename="${prefix}${current_timestamp}"
  new_snapshot="${source}@${new_basename}"

  log "Job ${job_id}: creating send snapshot ${new_snapshot}"
  if ! zfs snapshot "$new_snapshot"; then
    COUNT_JOBS_FAILED=$((COUNT_JOBS_FAILED + 1))
    set_user_failure \
      "Failed to create send snapshot '${new_snapshot}'." \
      "Check source dataset health and free space, then run again."
    log "Job ${job_id}: snapshot creation failed for ${new_snapshot}."
    return 1
  fi
  COUNT_CREATED=$((COUNT_CREATED + 1))

  if [[ -n "$latest_common_name" ]]; then
    cmd="zfs send -I $(printf '%q' "${source}@${latest_common_name}") $(printf '%q' "$new_snapshot") | zfs receive -uF $(printf '%q' "$dest")"
    description="zfs send incremental ${source}@${latest_common_name} -> ${new_snapshot}"
    log "Job ${job_id}: sending incremental stream from ${source}@${latest_common_name} to ${dest}."
  else
    cmd="zfs send $(printf '%q' "$new_snapshot") | zfs receive -uF $(printf '%q' "$dest")"
    description="zfs send full ${new_snapshot}"
    log "Job ${job_id}: no common send snapshot found; starting a full send to ${dest}."
  fi

  if ! run_pipeline_command "$description" 0 "$cmd"; then
    COUNT_JOBS_FAILED=$((COUNT_JOBS_FAILED + 1))
    set_user_failure \
      "ZFS send failed for '${source}' -> '${dest}'." \
      "Check destination dataset health, connectivity, and free space, then run again."
    log "Job ${job_id}: send/receive failed for ${source} -> ${dest}."
    return 1
  fi

  log "Job ${job_id}: replication completed successfully. Keeping newest send snapshot ${new_basename}."
  cleanup_job_snapshots_keep_newest "$source" "$prefix" "$new_basename" "source_cleanup"
  cleanup_job_snapshots_keep_newest "$dest" "$prefix" "$new_basename" "destination_cleanup"
  COUNT_JOBS_SENT=$((COUNT_JOBS_SENT + 1))
  return 0
}

if [[ -f "$CONFIG_FILE" ]]; then
  load_config_file "$CONFIG_FILE"
fi

trap 'record_error_context "$LINENO" "$BASH_COMMAND"' ERR
trap on_exit EXIT
trap 'handle_stop_signal TERM' TERM
trap 'handle_stop_signal INT' INT

RUN_SUMMARY_ENABLED=1
RUN_STARTED_AT_EPOCH="$(date +%s)"
RUN_STARTED_AT_HUMAN="$(date +'%Y-%m-%d %H:%M:%S %Z')"
NOW_EPOCH="$RUN_STARTED_AT_EPOCH"

SEND_JOBS="$(trim "$SEND_JOBS")"
SEND_SNAPSHOT_PREFIX="$(trim "$SEND_SNAPSHOT_PREFIX")"
KEEP_LOG_RUNS="$(trim "$KEEP_LOG_RUNS")"
POST_DELETE_RECHECK_WAIT_SECONDS="$(trim "$POST_DELETE_RECHECK_WAIT_SECONDS")"
POST_DELETE_RECHECK_INTERVAL_SECONDS="$(trim "$POST_DELETE_RECHECK_INTERVAL_SECONDS")"

if [[ -z "$SEND_JOBS" ]]; then
  log "No ZFS send jobs are configured. Exiting."
  exit 0
fi

if [[ -z "$SEND_SNAPSHOT_PREFIX" ]]; then
  fail_config "Send snapshot prefix is empty, which is unsafe." "Set a non-empty send prefix in the ZFS send settings."
fi

if [[ "$SEND_SNAPSHOT_PREFIX" == *"@"* ]]; then
  fail_config "Send snapshot prefix cannot contain '@'." "Remove '@' from the send prefix and save again."
fi

if [[ ! "$SEND_SNAPSHOT_PREFIX" =~ ^[A-Za-z0-9._:-]+$ ]]; then
  fail_config "Send snapshot prefix contains unsupported characters." "Use only letters, numbers, dot, underscore, colon, or dash in the send prefix."
fi

require_numeric_in_range "KEEP_LOG_RUNS" "$KEEP_LOG_RUNS" 1 50
require_numeric_in_range "POST_DELETE_RECHECK_WAIT_SECONDS" "$POST_DELETE_RECHECK_WAIT_SECONDS" 0 300
require_numeric_in_range "POST_DELETE_RECHECK_INTERVAL_SECONDS" "$POST_DELETE_RECHECK_INTERVAL_SECONDS" 1 60

if ! command -v zfs >/dev/null 2>&1 || ! command -v zpool >/dev/null 2>&1; then
  fail_config "zfs/zpool commands are not available." "Install or enable ZFS on this server, then run again."
fi

prepare_runtime_state
acquire_lock
parse_send_jobs

log "${LOG_RUN_MARKER} ts=$(date +'%Y-%m-%d %H:%M:%S %Z') pid=$$"
log "Config: send_jobs='${SEND_JOBS}' prefix='${SEND_SNAPSHOT_PREFIX}'"
log "Jobs loaded: ${#JOB_IDS[@]}"

if (( ${#JOB_IDS[@]} == 0 )); then
  log "No valid ZFS send jobs remain after parsing. Exiting."
  exit 0
fi

for job_id in "${JOB_IDS[@]}"; do
  abort_if_stop_requested
  if ! run_send_job "$job_id"; then
    :
  fi
 done

if (( COUNT_JOBS_FAILED > 0 )); then
  die "One or more ZFS send jobs failed."
fi

log "All due ZFS send jobs completed."
exit 0
