#!/bin/bash
set -Eeuo pipefail

# shellcheck source=/dev/null
source /usr/local/emhttp/plugins/zfs.autosnapshot/scripts/ops-queue-lib.sh

spawn_send_worker() {
  nohup /usr/local/sbin/zfs_autosnapshot_send_worker >> "$LOG_FILE" 2>&1 < /dev/null &
}

spawn_delete_worker() {
  nohup /usr/local/sbin/zfs_autosnapshot_delete_worker >> "$LOG_FILE" 2>&1 < /dev/null &
}

# shellcheck disable=SC2034
enqueue_all_scheduled_jobs_now() {
  local now_epoch="$1"
  local requested_at job_id job_file
  # shellcheck disable=SC2034
  local -A job=()

  requested_at="$(date -u +'%Y-%m-%dT%H:%M:%SZ' -r "$now_epoch" 2>/dev/null || date -u +'%Y-%m-%dT%H:%M:%SZ')"

  for job_id in "${SCHEDULE_JOB_IDS[@]}"; do
    schedule_job_blocked "$job_id" && continue

    job=()
    job[JOB_ID]="send-${job_id}-manual-${now_epoch}"
    job[JOB_TYPE]="send"
    job[JOB_MODE]="scheduled"
    job[JOB_ACTION]="prepare"
    job[STATE]="queued"
    job[PHASE]="queued"
    job[REQUESTED_EPOCH]="$now_epoch"
    job[REQUESTED_AT]="$requested_at"
    job[QUEUE_SORT]="$now_epoch"
    job[WINDOW_KEY]="manual-${now_epoch}"
    job[SCHEDULE_JOB_ID]="$job_id"
    job[SOURCE_ROOT]="${SCHEDULE_SOURCE_ROOT[$job_id]}"
    job[DESTINATION_ROOT]="${SCHEDULE_DEST_ROOT[$job_id]}"
    job[INCLUDE_CHILDREN]="${SCHEDULE_INCLUDE_CHILDREN[$job_id]}"
    job[FREQUENCY]="${SCHEDULE_FREQUENCY[$job_id]}"
    job[THRESHOLD]="${SCHEDULE_THRESHOLD_RAW[$job_id]}"
    job[THRESHOLD_BYTES]="${SCHEDULE_THRESHOLD_BYTES[$job_id]}"
    job[SNAPSHOT_PREFIX_BASE]="$SEND_SNAPSHOT_PREFIX"
    job[SNAPSHOT_PREFIX]="$(job_prefix_for_schedule "$job_id")"
    job[ATTEMPT_COUNT]="0"
    job[RETRY_AT]="0"
    job[LAST_ERROR]=""
    job[LAST_MESSAGE]="Queued by manual run request."
    job[WORKER_PID]=""
    job[PROGRESS_PERCENT]="5"
    job[MEMBER_COUNT]="0"
    job[COMPLETES_SCHEDULE_WINDOW]="0"
    job_file="${OPS_JOBS_DIR}/$(printf '%010d-%s.job' "$now_epoch" "send-${job_id}-manual-${now_epoch}")"
    job_write "$job_file" job || true
  done
}

main() {
  local now_epoch manual_now=0

  while (( $# > 0 )); do
    case "$1" in
      --manual-now)
        manual_now=1
        ;;
    esac
    shift
  done

  ensure_runtime_layout || exit 1
  load_send_config
  require_numeric_in_range "SEND_MAX_PARALLEL" "$SEND_MAX_PARALLEL" 1 8 || SEND_MAX_PARALLEL="$DEFAULT_SEND_MAX_PARALLEL"
  parse_send_jobs_config

  exec >> "$LOG_FILE" 2>&1
  log "Queue kicker $$ starting"

  reconcile_stale_jobs
  prune_old_jobs

  now_epoch="$(date +%s)"
  if (( manual_now == 1 )); then
    enqueue_all_scheduled_jobs_now "$now_epoch"
  else
    enqueue_scheduled_send_jobs_due "$now_epoch" || true
  fi

  if ! unraid_array_actionable; then
    log "$(unraid_array_action_message). Queue workers remain paused until the array is actionable."
    exit 0
  fi

  while send_worker_slot_available; do
    claim_next_send_job "$now_epoch" candidate_path || break
    [[ -n "$candidate_path" ]] || break
    spawn_send_worker
    sleep 0.1
  done

  if ! delete_worker_running; then
    if delete_queue_has_backlog; then
      spawn_delete_worker
    fi
  fi

  log "Queue kicker $$ finished"
}

main "$@"
