#!/bin/bash
set -Eeuo pipefail

# shellcheck source=/dev/null
source /usr/local/emhttp/plugins/zfs.autosnapshot/scripts/ops-queue-lib.sh

spawn_send_worker() {
  local worker_lock_dir="$1"
  ZFSAS_WORKER_LOCK_DIR="$worker_lock_dir" nohup /usr/local/sbin/zfs_autosnapshot_send_worker >> "$LOG_FILE" 2>&1 < /dev/null &
}

spawn_pool_prep_worker() {
  local worker_lock_dir="$1"
  ZFSAS_WORKER_LOCK_DIR="$worker_lock_dir" nohup /usr/local/sbin/zfs_autosnapshot_send_worker --pool-prep-only >> "$LOG_FILE" 2>&1 < /dev/null &
}

spawn_delete_worker() {
  nohup /usr/local/sbin/zfs_autosnapshot_delete_worker >> "$LOG_FILE" 2>&1 < /dev/null &
}

# shellcheck disable=SC2034
enqueue_all_scheduled_jobs_now() {
  local now_epoch="$1"
  local requested_at job_id dest_pool run_group_id prep_job_id pool
  local -a run_jobs=()
  local -a run_pools=()
  local -A run_pool=()
  local -A pool_schedule_ids=()
  local -A seen_pool=()

  requested_at="$(date -u +'%Y-%m-%dT%H:%M:%SZ' -r "$now_epoch" 2>/dev/null || date -u +'%Y-%m-%dT%H:%M:%SZ')"
  run_group_id="manual-${now_epoch}"

  for job_id in "${SCHEDULE_JOB_IDS[@]}"; do
    schedule_job_blocked "$job_id" && continue
    dest_pool="$(schedule_destination_pool "$job_id" || true)"
    [[ -n "$dest_pool" ]] || continue
    run_jobs+=("$job_id")
    run_pool["$job_id"]="$dest_pool"
    pool_schedule_ids["$dest_pool"]="${pool_schedule_ids[$dest_pool]:-}${job_id} "
    if [[ -z "${seen_pool[$dest_pool]:-}" ]]; then
      seen_pool["$dest_pool"]=1
      run_pools+=("$dest_pool")
    fi
  done

  for pool in "${run_pools[@]}"; do
    enqueue_pool_prep_job "$pool" "$run_group_id" "$now_epoch" "$requested_at" "${pool_schedule_ids[$pool]}" || true
  done

  for job_id in "${run_jobs[@]}"; do
    pool="${run_pool[$job_id]}"
    prep_job_id="$(pool_prep_job_id_for_group "$pool" "$run_group_id")"
    enqueue_scheduled_prepare_job "$job_id" "manual-${now_epoch}" "$now_epoch" "$requested_at" \
      "$prep_job_id" "$pool" "$run_group_id" "0" "Queued by manual run request." || true
  done
}

main() {
  local now_epoch manual_now=0 candidate_path worker_lock_dir max_send_workers

  while (( $# > 0 )); do
    case "$1" in
      --manual-now)
        manual_now=1
        ;;
    esac
    shift
  done

  ensure_runtime_layout || exit 1
  load_send_config
  require_numeric_in_range "SEND_MAX_PARALLEL" "$SEND_MAX_PARALLEL" 1 8 || SEND_MAX_PARALLEL="$DEFAULT_SEND_MAX_PARALLEL"
  parse_send_jobs_config

  compact_shared_send_log_if_safe || true
  exec >> "$LOG_FILE" 2>&1
  log "Queue kicker $$ starting"

  reconcile_stale_jobs
  prune_old_jobs

  now_epoch="$(date +%s)"
  if (( manual_now == 1 )); then
    enqueue_all_scheduled_jobs_now "$now_epoch"
  else
    enqueue_scheduled_send_jobs_due "$now_epoch" || true
  fi

  if ! unraid_array_actionable; then
    log "$(unraid_array_action_message). Queue workers remain paused until the array is actionable."
    exit 0
  fi

  while pool_prep_worker_slot_available; do
    claim_next_send_job "$now_epoch" candidate_path pool_prep || break
    [[ -n "$candidate_path" ]] || break
    worker_lock_dir=""
    acquire_send_worker_launch_slot pool_prep 8 worker_lock_dir || break
    spawn_pool_prep_worker "$worker_lock_dir"
    sleep 0.1
  done

  max_send_workers="$SEND_MAX_PARALLEL"
  [[ "$max_send_workers" =~ ^[0-9]+$ ]] || max_send_workers="$DEFAULT_SEND_MAX_PARALLEL"
  (( max_send_workers >= 1 )) || max_send_workers=1
  while send_worker_slot_available; do
    claim_next_send_job "$now_epoch" candidate_path non_pool_prep || break
    [[ -n "$candidate_path" ]] || break
    worker_lock_dir=""
    acquire_send_worker_launch_slot worker "$max_send_workers" worker_lock_dir || break
    spawn_send_worker "$worker_lock_dir"
    sleep 0.1
  done

  if ! delete_worker_running; then
    if delete_queue_has_backlog; then
      spawn_delete_worker
    fi
  fi

  log "Queue kicker $$ finished"
}

main "$@"
