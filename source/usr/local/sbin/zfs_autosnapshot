#!/bin/bash
set -Eeuo pipefail
umask 077

# =============================================================================
# ZFS Automatic Snapshot Script for Unraid
#
# What it does (in this order):
#   1) Time-based retention cleanup (ONLY snapshots with PREFIX)
#   2) Space-based cleanup if pool free space falls below configured thresholds
#   3) Creates a fresh snapshot for each configured dataset
#
# SAFETY:
#   - This script ONLY destroys snapshots whose name contains "@${PREFIX}".
#   - Any snapshots not matching that prefix are never touched.
# =============================================================================

CONFIG_DIR="/boot/config/plugins/zfs.autosnapshot"
CONFIG_FILE="${CONFIG_FILE:-$CONFIG_DIR/zfs_autosnapshot.conf}"
PLUGIN_NAME="zfs.autosnapshot"
RUNTIME_DIR="/var/run/zfs-autosnapshot"

# -----------------------------------------------------------------------------
# Defaults (can be overridden in config file)
# -----------------------------------------------------------------------------
DATASETS=""
PREFIX="autosnapshot-"
DRY_RUN=0

KEEP_ALL_FOR_DAYS=14
KEEP_DAILY_UNTIL_DAYS=30
KEEP_WEEKLY_UNTIL_DAYS=183

LOCKFILE="${RUNTIME_DIR}/zfs_autosnapshot.lock"
LOCKDIR="${RUNTIME_DIR}/zfs_autosnapshot.lockdir"
LOG_FILE="/var/log/zfs_autosnapshot.log"
SUMMARY_LOG_FILE="/var/log/zfs_autosnapshot.last.log"
LEASE_STATE_FILE="${CONFIG_DIR}/snapshot_leases.tsv"
LOG_RUN_MARKER="[RUN_START]"
KEEP_LOG_RUNS="${KEEP_LOG_RUNS:-2}"
# If a single snapshot destroy runs longer than this, treat it as hung and exit.
DESTROY_HANG_TIMEOUT_SECONDS=120
# After deleting a snapshot, give ZFS/free-space accounting a short window to
# reflect the reclaim before concluding the delete made no progress.
POST_DELETE_RECHECK_WAIT_SECONDS="${POST_DELETE_RECHECK_WAIT_SECONDS:-3}"
POST_DELETE_RECHECK_INTERVAL_SECONDS="${POST_DELETE_RECHECK_INTERVAL_SECONDS:-2}"

RUN_STARTED_AT_EPOCH=0
RUN_STARTED_AT_HUMAN=""
RUN_MODE="normal"
RUN_DATASET_COUNT=0
RUN_POOL_COUNT=0
RUN_ERROR_CONTEXT=""
RUN_USER_ERROR=""
RUN_USER_ACTION=""
RUN_SUMMARY_ENABLED=0
LOCK_FALLBACK_HELD=0

COUNT_CREATED=0
COUNT_DELETED_TOTAL=0
COUNT_DELETED_AGE=0
COUNT_DELETED_DAILY=0
COUNT_DELETED_WEEKLY=0
COUNT_DELETED_SPACE=0
COUNT_DELETED_ZERO_CHANGE=0
COUNT_SKIPPED_HELD=0
COUNT_SKIPPED_NON_RECLAIMABLE=0
COUNT_LOW_SPACE_UNRESOLVED=0

# shellcheck disable=SC2034  # tracked through indirect helpers
ACTIVE_LEASE_SNAPSHOTS=$'\n'
# shellcheck disable=SC2034  # tracked through indirect helpers
SKIPPED_HELD_SNAPSHOTS=$'\n'
# shellcheck disable=SC2034  # tracked through indirect helpers
SKIPPED_NON_RECLAIMABLE_SNAPSHOTS=$'\n'
# shellcheck disable=SC2034  # tracked through indirect helpers
LOW_SPACE_UNRESOLVED_POOLS=$'\n'
# shellcheck disable=SC2034  # used through nameref/default helper path
declare -A NO_CONSTRAINT_RECLAIM=()
# shellcheck disable=SC2034  # tracked through indirect helpers
LOW_SPACE_UNRESOLVED_NOTES=$'\n'
# shellcheck disable=SC2034  # tracked through indirect helpers
PROTECTED_LATEST_SNAPSHOTS=$'\n'
declare -A LOW_SPACE_DATASET_SNAPSHOT_LINES=()
declare -A LOW_SPACE_DATASET_CANDIDATE_SNAP=()
declare -A LOW_SPACE_DATASET_CANDIDATE_USED=()
declare -A LOW_SPACE_DATASET_CANDIDATE_EPOCH=()
declare -A LOW_SPACE_DATASET_ANY_SNAPS=()
declare -A LOW_SPACE_DATASET_GENERATION=()
declare -A LOW_SPACE_DATASET_REFRESH_GENERATION=()

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------
log() { echo "$@"; }

trim() {
	local s="$1"
	s="${s#"${s%%[![:space:]]*}"}"
	s="${s%"${s##*[![:space:]]}"}"
	printf '%s' "$s"
}

set_user_failure() {
	local what="$1"
	local action="$2"
	RUN_USER_ERROR="$what"
	RUN_USER_ACTION="$action"
}

die() {
	local message="$*"

	if [[ -z "$RUN_USER_ERROR" ]]; then
		RUN_USER_ERROR="$message"
	fi

	if [[ -z "$RUN_USER_ACTION" ]]; then
		RUN_USER_ACTION="Open ZFS Auto Snapshot settings, fix the configuration, then run again."
	fi

	log "ERROR: $message" >&2
	exit 1
}

fail_config() {
	local message="$1"
	local action="$2"
	set_user_failure "$message" "$action"
	die "$message"
}

record_error_context() {
	local line="$1"
	local cmd="$2"
	RUN_ERROR_CONTEXT="line ${line}: ${cmd}"

	if [[ -z "$RUN_USER_ERROR" ]]; then
		RUN_USER_ERROR="The run stopped unexpectedly because an internal command failed."
	fi

	if [[ -z "$RUN_USER_ACTION" ]]; then
		RUN_USER_ACTION="Open the Debug Log, fix the reported command problem, then run again."
	fi
}

parse_config_value() {
	local raw="$1"
	local value

	value="$(trim "$raw")"
	[[ -n "$value" ]] || {
		printf ''
		return 0
	}

	if [[ "$value" == \"*\" && "$value" == *\" && ${#value} -ge 2 ]]; then
		value="${value:1:${#value}-2}"
		value="${value//\\\\/\\}"
		value="${value//\\\"/\"}"
		printf '%s' "$value"
		return 0
	fi

	if [[ "$value" == \'*\' && "$value" == *\' && ${#value} -ge 2 ]]; then
		value="${value:1:${#value}-2}"
		printf '%s' "$value"
		return 0
	fi

	value="${value%%#*}"
	value="$(trim "$value")"
	printf '%s' "$value"
}

apply_config_key() {
	local key="$1"
	local value="$2"

	case "$key" in
	DATASETS | PREFIX | DRY_RUN | KEEP_ALL_FOR_DAYS | KEEP_DAILY_UNTIL_DAYS | KEEP_WEEKLY_UNTIL_DAYS | KEEP_LOG_RUNS)
		if [[ "$value" == *$'\n'* || "$value" == *$'\r'* ]]; then
			return 0
		fi
		printf -v "$key" '%s' "$value"
		;;
	esac
}

load_config_file() {
	local path="$1"
	local line key raw value

	[[ -f "$path" ]] || return 0

	while IFS= read -r line || [[ -n "$line" ]]; do
		[[ "$line" =~ ^[[:space:]]*# ]] && continue
		[[ "$line" =~ ^[[:space:]]*$ ]] && continue

		if [[ "$line" =~ ^[[:space:]]*([A-Z0-9_]+)[[:space:]]*=(.*)$ ]]; then
			key="${BASH_REMATCH[1]}"
			raw="${BASH_REMATCH[2]}"
			value="$(parse_config_value "$raw")"
			apply_config_key "$key" "$value"
		fi
	done <"$path"
}

require_numeric_in_range() {
	local name="$1"
	local value="$2"
	local min="$3"
	local max="$4"

	[[ "$value" =~ ^[0-9]+$ ]] || fail_config "${name} must be an integer." "Set ${name} to a whole number between ${min} and ${max}."

	if ((value < min || value > max)); then
		fail_config "${name} is out of range (${value})." "Set ${name} between ${min} and ${max}."
	fi
}

ensure_existing_directory() {
	local path="$1"
	local label="$2"

	if [[ -z "$path" ]]; then
		fail_config "${label} path is empty." "Reset ${label} to its default location and run again."
	fi

	if [[ -L "$path" ]]; then
		fail_config "${label} path '$path' is a symlink, which is unsafe." "Remove the symlink and restore a normal directory."
	fi

	if [[ ! -d "$path" ]]; then
		fail_config "${label} path '$path' is missing." "Create the directory or restore the default path, then run again."
	fi
}

ensure_secure_directory() {
	local path="$1"
	local mode="$2"
	local label="$3"

	if [[ -z "$path" ]]; then
		fail_config "${label} path is empty." "Reset ${label} to its default location and run again."
	fi

	if [[ -L "$path" ]]; then
		fail_config "${label} path '$path' is a symlink, which is unsafe." "Remove the symlink and restore a normal directory."
	fi

	if [[ -e "$path" && ! -d "$path" ]]; then
		fail_config "${label} path '$path' is not a directory." "Remove the unexpected file and try again."
	fi

	if [[ ! -d "$path" ]]; then
		mkdir -p "$path" || fail_config "Unable to create ${label} '$path'." "Check filesystem permissions, then run again."
	fi

	chmod "$mode" "$path" 2>/dev/null || true
	chown root:root "$path" 2>/dev/null || true
}

ensure_secure_file() {
	local path="$1"
	local mode="$2"
	local label="$3"
	local parent

	if [[ -z "$path" ]]; then
		fail_config "${label} path is empty." "Reset ${label} to its default location and run again."
	fi

	parent="$(dirname "$path")"
	ensure_existing_directory "$parent" "${label} parent directory"

	if [[ -L "$path" ]]; then
		fail_config "${label} '$path' is a symlink, which is unsafe." "Remove the symlink and try again."
	fi

	if [[ -e "$path" && ! -f "$path" ]]; then
		fail_config "${label} '$path' is not a regular file." "Remove the unexpected path and try again."
	fi

	: >>"$path" || fail_config "Unable to open ${label} '$path'." "Check filesystem permissions, then run again."
	chmod "$mode" "$path" 2>/dev/null || true
	chown root:root "$path" 2>/dev/null || true
}

prepare_runtime_state() {
	ensure_secure_directory "$RUNTIME_DIR" 0700 "Runtime directory"
	ensure_secure_file "$LOCKFILE" 0600 "Lock file"
	ensure_existing_directory "$(dirname "$LOG_FILE")" "Debug log directory"
	ensure_existing_directory "$(dirname "$SUMMARY_LOG_FILE")" "Summary log directory"
	ensure_secure_file "$LOG_FILE" 0600 "Debug log"
	ensure_secure_file "$SUMMARY_LOG_FILE" 0600 "Run summary log"
}

increment_delete_counter() {
	local reason="$1"

	COUNT_DELETED_TOTAL=$((COUNT_DELETED_TOTAL + 1))

	case "$reason" in
	age_window)
		COUNT_DELETED_AGE=$((COUNT_DELETED_AGE + 1))
		;;
	daily_consolidation)
		COUNT_DELETED_DAILY=$((COUNT_DELETED_DAILY + 1))
		;;
	weekly_consolidation)
		COUNT_DELETED_WEEKLY=$((COUNT_DELETED_WEEKLY + 1))
		;;
	space_pressure)
		COUNT_DELETED_SPACE=$((COUNT_DELETED_SPACE + 1))
		;;
	zero_change_housekeeping)
		COUNT_DELETED_ZERO_CHANGE=$((COUNT_DELETED_ZERO_CHANGE + 1))
		;;
	esac
}

do_destroy() {
	local snap="$1"
	local reason="${2:-unknown}"

	if ((DRY_RUN)); then
		log "[DRY_RUN] zfs destroy '$snap'"
		increment_delete_counter "$reason"
	else
		destroy_with_watchdog "$snap"
		increment_delete_counter "$reason"
	fi
}

destroy_with_watchdog() {
	local snap="$1"
	local pid start now elapsed wait_rc

	zfs destroy "$snap" &
	pid=$!
	start="$(date +%s)"

	while kill -0 "$pid" 2>/dev/null; do
		now="$(date +%s)"
		elapsed=$((now - start))

		if ((elapsed >= DESTROY_HANG_TIMEOUT_SECONDS)); then
			log "Snapshot destroy timed out after ${DESTROY_HANG_TIMEOUT_SECONDS}s: $snap"
			kill "$pid" >/dev/null 2>&1 || true
			sleep 1
			kill -9 "$pid" >/dev/null 2>&1 || true
			wait "$pid" 2>/dev/null || true

			RUN_ERROR_CONTEXT="zfs destroy timed out for '$snap' after ${DESTROY_HANG_TIMEOUT_SECONDS}s"
			set_user_failure \
				"Snapshot deletion did not finish within ${DESTROY_HANG_TIMEOUT_SECONDS} seconds, so this run stopped to avoid hanging." \
				"Let I/O pressure drop, then wait for the next scheduled run (or run manually) to continue cleanup."
			die "Snapshot destroy timed out for '$snap' after ${DESTROY_HANG_TIMEOUT_SECONDS}s."
		fi

		sleep 1
	done

	if wait "$pid"; then
		wait_rc=0
	else
		wait_rc=$?
	fi

	if ((wait_rc != 0)); then
		RUN_ERROR_CONTEXT="zfs destroy failed for '$snap' (exit ${wait_rc})"
		set_user_failure \
			"Snapshot deletion failed for '$snap' because ZFS returned an internal error." \
			"Check Tools > System Log for ZFS errors, run 'zpool status', then run again."
		die "Snapshot destroy command failed for '$snap' (exit ${wait_rc})."
	fi
}

do_snapshot() {
	local snap="$1"

	if ((DRY_RUN)); then
		log "[DRY_RUN] zfs snapshot '$snap'"
		COUNT_CREATED=$((COUNT_CREATED + 1))
	else
		if ! zfs snapshot "$snap"; then
			RUN_ERROR_CONTEXT="zfs snapshot failed for '$snap'"
			set_user_failure \
				"Snapshot creation failed for '$snap'." \
				"Check dataset health and free space, then run again."
			die "Snapshot create command failed for '$snap'."
		fi
		COUNT_CREATED=$((COUNT_CREATED + 1))
	fi
}

# Convert "100G", "500MB", "2T", etc. into bytes (1024-based).
threshold_to_bytes() {
	local raw="$1"
	local upper num unit

	upper="$(echo "$raw" | tr '[:lower:]' '[:upper:]')"
	upper="${upper%B}"

	num="${upper%%[!0-9]*}"
	unit="${upper#"$num"}"

	if [[ -z "$num" || ! "$num" =~ ^[0-9]+$ ]]; then
		fail_config "Bad threshold '$raw'." "Use thresholds like 500M, 100G, or 2T."
	fi

	case "$unit" in
	K) echo $((num * 1024)) ;;
	M) echo $((num * 1024 * 1024)) ;;
	G) echo $((num * 1024 * 1024 * 1024)) ;;
	T) echo $((num * 1024 * 1024 * 1024 * 1024)) ;;
	*) fail_config "Bad unit in '$raw'." "Use K, M, G, or T (optional trailing B)." ;;
	esac
}

get_pool_avail() {
	local value
	value="$(zfs list -o avail -H -p "$1" 2>/dev/null || true)"
	[[ "$value" =~ ^[0-9]+$ ]] && echo "$value" || echo ""
}

# "freeing" may be missing or "-". Treat as 0 if not numeric.
get_pool_freeing() {
	local value
	value="$(zpool get -H -o value freeing "$1" 2>/dev/null || true)"
	[[ "$value" =~ ^[0-9]+$ ]] && echo "$value" || echo 0
}

get_pool_effective_avail() {
	local pool="$1"
	local avail freeing

	avail="$(get_pool_avail "$pool")"
	[[ -n "$avail" ]] || {
		echo ""
		return 1
	}

	freeing="$(get_pool_freeing "$pool")"
	echo $((avail + freeing))
}

constraints_are_pool_only() {
	local constraints_var_name="$1"
	local constraint
	local -n constraints_ref="$constraints_var_name"

	(( ${#constraints_ref[@]} > 0 )) || return 1

	for constraint in "${constraints_ref[@]}"; do
		[[ "$constraint" == pool:* ]] || return 1
	done

	return 0
}

should_wait_for_post_delete_recheck() {
	local dataset="$1"
	local constraints_var_name="$2"
	local after_effective_avail="$3"
	local before_effective_avail="$4"
	local pool freeing

	if (( POST_DELETE_RECHECK_WAIT_SECONDS <= 0 )); then
		return 1
	fi

	constraints_are_pool_only "$constraints_var_name" || return 0

	pool="${dataset%%/*}"
	freeing="$(get_pool_freeing "$pool")"

	if [[ "$freeing" =~ ^[0-9]+$ ]]; then
		if (( freeing > 0 )); then
			return 1
		fi

		if (( after_effective_avail != before_effective_avail )); then
			return 1
		fi
	fi

	return 0
}

wait_for_effective_avail_change() {
	local pool="$1"
	local baseline="$2"
	local max_wait="$3"
	local interval="$4"
	local waited=0
	local effective_now

	while :; do
		effective_now="$(get_pool_effective_avail "$pool")"
		[[ -n "$effective_now" ]] || {
			echo ""
			return 1
		}

		if ((effective_now > baseline)); then
			echo "$effective_now"
			return 0
		fi

		if ((waited >= max_wait)); then
			echo "$effective_now"
			return 0
		fi

		sleep "$interval"
		waited=$((waited + interval))
	done
}

newline_set_contains() {
	local haystack="$1"
	local needle="$2"
	[[ "$haystack" == *$'\n'"$needle"$'\n'* ]]
}

remember_newline_entry() {
	local var_name="$1"
	local value="$2"
	local current="${!var_name:-$'\n'}"

	if newline_set_contains "$current" "$value"; then
		return 1
	fi

	printf -v "$var_name" '%s%s\n' "$current" "$value"
	return 0
}

emit_newline_entries() {
	local haystack="$1"
	printf '%s' "$haystack" | sed '/^[[:space:]]*$/d'
}

record_skipped_held_snapshot() {
	local snap="$1"

	if remember_newline_entry SKIPPED_HELD_SNAPSHOTS "$snap"; then
		COUNT_SKIPPED_HELD=$((COUNT_SKIPPED_HELD + 1))
		return 0
	fi

	return 1
}

record_skipped_non_reclaimable_snapshot() {
	local snap="$1"

	if remember_newline_entry SKIPPED_NON_RECLAIMABLE_SNAPSHOTS "$snap"; then
		COUNT_SKIPPED_NON_RECLAIMABLE=$((COUNT_SKIPPED_NON_RECLAIMABLE + 1))
		return 0
	fi

	return 1
}

remember_protected_latest_snapshot() {
	local snap="$1"
	remember_newline_entry PROTECTED_LATEST_SNAPSHOTS "$snap" >/dev/null 2>&1 || true
}

record_low_space_unresolved_pool() {
	local pool="$1"
	local note="$2"

	if remember_newline_entry LOW_SPACE_UNRESOLVED_POOLS "$pool"; then
		COUNT_LOW_SPACE_UNRESOLVED=$((COUNT_LOW_SPACE_UNRESOLVED + 1))
	fi

	remember_newline_entry LOW_SPACE_UNRESOLVED_NOTES "$pool: $note" >/dev/null 2>&1 || true
}

load_active_leases() {
	local line snap expires state

	ACTIVE_LEASE_SNAPSHOTS=$'\n'

	[[ -f "$LEASE_STATE_FILE" ]] || return 0

	while IFS= read -r line || [[ -n "$line" ]]; do
		[[ "$line" =~ ^[[:space:]]*# ]] && continue
		[[ "$line" =~ ^[[:space:]]*$ ]] && continue

		IFS=$'\t' read -r snap expires state _ <<<"$line"
		snap="$(trim "$snap")"
		expires="$(trim "$expires")"
		state="$(trim "$state")"

		[[ -n "$snap" ]] || continue
		[[ "$expires" =~ ^[0-9]+$ ]] || continue
		[[ -n "$state" ]] || state="active"
		[[ "$state" == "active" ]] || continue

		if ((expires > NOW_EPOCH)); then
			remember_newline_entry ACTIVE_LEASE_SNAPSHOTS "$snap" >/dev/null 2>&1 || true
		fi
	done <"$LEASE_STATE_FILE"
}

snapshot_has_active_lease() {
	local snap="$1"
	newline_set_contains "$ACTIVE_LEASE_SNAPSHOTS" "$snap"
}

snapshot_is_protected_latest() {
	local snap="$1"
	newline_set_contains "$PROTECTED_LATEST_SNAPSHOTS" "$snap"
}

load_snapshot_property_maps() {
	local dataset="$1"
	# shellcheck disable=SC2034  # nameref targets are used by the caller
	local -n used_ref="$2"
	# shellcheck disable=SC2034  # nameref targets are used by the caller
	local -n written_ref="$3"
	# shellcheck disable=SC2034  # nameref targets are used by the caller
	local -n userrefs_ref="$4"
	local metadata snap property value

	used_ref=()
	written_ref=()
	userrefs_ref=()

	metadata="$(zfs get -H -p -o name,property,value -t snapshot -r used,written,userrefs "$dataset" 2>/dev/null | grep -F "@${PREFIX}" || true)"

	while IFS=$'\t' read -r snap property value; do
		[[ -n "$snap" && -n "$property" ]] || continue

		case "$property" in
		used)
			# shellcheck disable=SC2034  # nameref write consumed by caller
			used_ref["$snap"]="$value"
			;;
		written)
			# shellcheck disable=SC2034  # nameref write consumed by caller
			written_ref["$snap"]="$value"
			;;
		userrefs)
			# shellcheck disable=SC2034  # nameref write consumed by caller
			userrefs_ref["$snap"]="$value"
			;;
		esac
	done <<<"$metadata"
}

load_dataset_snapshot_inventory() {
	local dataset="$1"
	local inventory

	if [[ -n "${LOW_SPACE_DATASET_SNAPSHOT_LINES[$dataset]+set}" ]]; then
		return 0
	fi

	inventory="$(zfs list -H -p -t snapshot -o name,creation -S creation -r "$dataset" | grep -F "@${PREFIX}" | sort -t $'\t' -k2,2n || true)"
	LOW_SPACE_DATASET_SNAPSHOT_LINES["$dataset"]="$inventory"
	LOW_SPACE_DATASET_GENERATION["$dataset"]=${LOW_SPACE_DATASET_GENERATION["$dataset"]:-0}
	LOW_SPACE_DATASET_REFRESH_GENERATION["$dataset"]=-1
}

refresh_dataset_cleanup_candidate() {
	local dataset="$1"
	local count_skips="${2:-1}"
	local inventory snap_name snap_created protection_reason used_bytes written_bytes
	local chain_start="" chain_start_epoch="" chain_start_used=0 found_snapshots=0
	local selected_snap="" selected_epoch="" selected_used=0
	local -A space_used_map=()
	local -A space_userrefs_map=()
	local -A space_written_map=()

	load_dataset_snapshot_inventory "$dataset"
	inventory="${LOW_SPACE_DATASET_SNAPSHOT_LINES[$dataset]}"
	load_snapshot_property_maps "$dataset" space_used_map space_written_map space_userrefs_map

	while IFS=$'\t' read -r snap_name snap_created; do
		[[ -n "$snap_name" && -n "$snap_created" ]] || continue

		if newline_set_contains "$simulated_deleted_snaps" "$snap_name"; then
			continue
		fi

		found_snapshots=1

		if snapshot_is_protected_latest "$snap_name"; then
			chain_start=""
			chain_start_epoch=""
			chain_start_used=0
			continue
		fi

		protection_reason="$(snapshot_protection_reason "$snap_name" "${space_userrefs_map[$snap_name]:-0}" || true)"
		if [[ -n "$protection_reason" ]]; then
			if ((count_skips)) && record_skipped_held_snapshot "$snap_name"; then
				log "Low-space cleanup -> skipping held/leased snapshot: $snap_name (${protection_reason})"
			fi
			chain_start=""
			chain_start_epoch=""
			chain_start_used=0
			continue
		fi

		used_bytes="$(snapshot_numeric_property "${space_used_map[$snap_name]:-0}" 0)"
		written_bytes="$(snapshot_numeric_property "${space_written_map[$snap_name]:-0}" 0)"

		if [[ -z "$chain_start" ]]; then
			chain_start="$snap_name"
			chain_start_epoch="$snap_created"
			chain_start_used="$used_bytes"
		fi

		if ((used_bytes > 0)); then
			selected_snap="$chain_start"
			selected_epoch="$chain_start_epoch"
			selected_used="$chain_start_used"
			break
		fi

		if ((count_skips)) && record_skipped_non_reclaimable_snapshot "$snap_name"; then
			log "Low-space cleanup -> snapshot currently shows no immediate reclaim: $snap_name (used=${used_bytes} written=${written_bytes}); it will only be deleted if it leads to an older reclaimable chain."
		fi
	done <<<"$inventory"

	LOW_SPACE_DATASET_CANDIDATE_SNAP["$dataset"]="$selected_snap"
	LOW_SPACE_DATASET_CANDIDATE_USED["$dataset"]="$selected_used"
	LOW_SPACE_DATASET_CANDIDATE_EPOCH["$dataset"]="$selected_epoch"
	LOW_SPACE_DATASET_ANY_SNAPS["$dataset"]="$found_snapshots"
	LOW_SPACE_DATASET_REFRESH_GENERATION["$dataset"]="${LOW_SPACE_DATASET_GENERATION[$dataset]:-0}"
}

ensure_dataset_cleanup_candidate() {
	local dataset="$1"
	local count_skips="${2:-1}"
	local generation refreshed_generation

	load_dataset_snapshot_inventory "$dataset"
	generation="${LOW_SPACE_DATASET_GENERATION[$dataset]:-0}"
	refreshed_generation="${LOW_SPACE_DATASET_REFRESH_GENERATION[$dataset]:--1}"

	if [[ "$generation" != "$refreshed_generation" ]]; then
		refresh_dataset_cleanup_candidate "$dataset" "$count_skips"
	fi
}

mark_dataset_cleanup_candidate_dirty() {
	local dataset="$1"
	LOW_SPACE_DATASET_GENERATION["$dataset"]=$(( ${LOW_SPACE_DATASET_GENERATION["$dataset"]:-0} + 1 ))
}

mark_cleanup_candidates_dirty_for_snapshot() {
	local snap="$1"
	local actual_dataset="${snap%@*}"
	local pair_dataset

	for pair in "${pairs[@]}"; do
		pair_dataset="${pair%:*}"
		if dataset_is_within_scope "$actual_dataset" "$pair_dataset"; then
			mark_dataset_cleanup_candidate_dirty "$pair_dataset"
		fi
	done
}

snapshot_numeric_property() {
	local raw="$1"
	local fallback="${2:-0}"

	if [[ "$raw" =~ ^[0-9]+$ ]]; then
		echo "$raw"
	else
		echo "$fallback"
	fi
}

snapshot_protection_reason() {
	local snap="$1"
	local userrefs_raw="${2:-0}"
	local userrefs

	userrefs="$(snapshot_numeric_property "$userrefs_raw" 0)"

	if ((userrefs > 0)); then
		echo "held (${userrefs} user reference(s))"
		return 0
	fi

	if snapshot_has_active_lease "$snap"; then
		echo "leased by the snapshot manager"
		return 0
	fi

	return 1
}

detect_plugin_version() {
	local manifest_path version

	for manifest_path in "/var/log/plugins/${PLUGIN_NAME}.plg" "/boot/config/plugins/${PLUGIN_NAME}.plg"; do
		[[ -r "$manifest_path" ]] || continue
		version="$(sed -n 's/.*<PLUGIN[^>]*version="\([^"]\+\)".*/\1/p' "$manifest_path" | head -n 1)"
		version="$(trim "$version")"
		if [[ -n "$version" ]]; then
			echo "$version"
			return 0
		fi
	done

	echo "unknown"
}

detect_unraid_version() {
	local value

	if [[ -r /etc/unraid-version ]]; then
		value="$(awk -F= '
      /^[[:space:]]*version[[:space:]]*=/ {
        gsub(/"/, "", $2)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2)
        print $2
        exit
      }
    ' /etc/unraid-version 2>/dev/null || true)"
		value="$(trim "$value")"
		if [[ -n "$value" ]]; then
			echo "$value"
			return 0
		fi

		value="$(head -n 1 /etc/unraid-version 2>/dev/null || true)"
		value="$(trim "$value")"
		if [[ -n "$value" ]]; then
			echo "$value"
			return 0
		fi
	fi

	if [[ -r /etc/os-release ]]; then
		value="$(awk -F= '/^PRETTY_NAME=/{gsub(/^"|"$/, "", $2); print $2; exit}' /etc/os-release 2>/dev/null || true)"
		value="$(trim "$value")"
		if [[ -n "$value" ]]; then
			echo "$value"
			return 0
		fi
	fi

	echo "unknown"
}

detect_zfs_version() {
	local value
	value="$(zfs version 2>/dev/null || zfs --version 2>/dev/null || true)"
	value="$(printf '%s' "$value" | tr '\n' ';' | sed 's/;[[:space:]]*/; /g; s/[[:space:];]*$//')"
	value="$(trim "$value")"
	[[ -n "$value" ]] && echo "$value" || echo "unknown"
}

detect_zpool_version() {
	local value
	value="$(zpool version 2>/dev/null || zpool --version 2>/dev/null || true)"
	value="$(printf '%s' "$value" | tr '\n' ';' | sed 's/;[[:space:]]*/; /g; s/[[:space:];]*$//')"
	value="$(trim "$value")"
	[[ -n "$value" ]] && echo "$value" || echo "unknown"
}

log_runtime_environment() {
	local plugin_version unraid_version zfs_version zpool_version
	local kernel_info bash_info path_zfs path_zpool pool_overview line

	plugin_version="$(detect_plugin_version)"
	unraid_version="$(detect_unraid_version)"
	zfs_version="$(detect_zfs_version)"
	zpool_version="$(detect_zpool_version)"
	kernel_info="$(uname -srmo 2>/dev/null || uname -sr 2>/dev/null || echo unknown)"
	bash_info="${BASH_VERSION:-unknown}"
	path_zfs="$(command -v zfs 2>/dev/null || echo missing)"
	path_zpool="$(command -v zpool 2>/dev/null || echo missing)"

	log "Environment: kernel='${kernel_info}' bash='${bash_info}'"
	log "Versions: plugin='${plugin_version}' unraid='${unraid_version}' zfs='${zfs_version}' zpool='${zpool_version}'"
	log "Commands: zfs='${path_zfs}' zpool='${path_zpool}' script='${BASH_SOURCE[0]}'"

	pool_overview="$(zpool list -H -o name,size,alloc,free,capacity,health 2>/dev/null || true)"
	if [[ -n "$pool_overview" ]]; then
		log "Pools(name size alloc free cap health):"
		while IFS= read -r line; do
			[[ -n "$line" ]] || continue
			log "  ${line}"
		done <<<"$pool_overview"
	fi
}

remember_pool_name() {
	local pool="$1"
	local i

	for i in "${!pool_names[@]}"; do
		if [[ "${pool_names[$i]}" == "$pool" ]]; then
			return 0
		fi
	done

	pool_names+=("$pool")
}

get_dataset_avail() {
	local dataset="$1"
	local value

	value="$(zfs get -H -p -o value available "$dataset" 2>/dev/null || zfs list -o avail -H -p "$dataset" 2>/dev/null || true)"
	[[ "$value" =~ ^[0-9]+$ ]] && echo "$value" || echo ""
}

get_dataset_numeric_property() {
	local dataset="$1"
	local property="$2"
	local value

	value="$(zfs get -H -p -o value "$property" "$dataset" 2>/dev/null || true)"
	[[ "$value" =~ ^[0-9]+$ ]] && echo "$value" || echo 0
}

get_dataset_quota_headroom() {
	local dataset="$1"
	local quota used

	quota="$(get_dataset_numeric_property "$dataset" "quota")"
	((quota > 0)) || {
		echo ""
		return 1
	}

	used="$(get_dataset_numeric_property "$dataset" "used")"
	if ((used >= quota)); then
		echo 0
	else
		echo $((quota - used))
	fi
}

get_dataset_refquota_headroom() {
	local dataset="$1"
	local refquota referenced

	refquota="$(get_dataset_numeric_property "$dataset" "refquota")"
	((refquota > 0)) || {
		echo ""
		return 1
	}

	referenced="$(get_dataset_numeric_property "$dataset" "referenced")"
	if ((referenced >= refquota)); then
		echo 0
	else
		echo $((refquota - referenced))
	fi
}

emit_dataset_capacity_constraints() {
	local dataset="$1"
	local pool="${dataset%%/*}"
	local current pool_effective quota_headroom refquota_headroom

	pool_effective="$(get_pool_effective_avail "$pool")"
	if [[ -n "$pool_effective" ]]; then
		printf 'pool:%s	%s
' "$pool" "$pool_effective"
	fi

	current="$dataset"
	while :; do
		quota_headroom="$(get_dataset_quota_headroom "$current" || true)"
		if [[ -n "$quota_headroom" ]]; then
			printf 'quota:%s	%s
' "$current" "$quota_headroom"
		fi

		[[ "$current" == "$pool" ]] && break
		current="${current%/*}"
	done

	refquota_headroom="$(get_dataset_refquota_headroom "$dataset" || true)"
	if [[ -n "$refquota_headroom" ]]; then
		printf 'refquota:%s	%s
' "$dataset" "$refquota_headroom"
	fi
}

get_dataset_active_constraints() {
	local dataset="$1"
	local delta_map_name="$2"
	local effective_var_name="$3"
	local active_constraints_var_name="$4"
	local token base adjusted best_value=""
	local -n delta_ref="$delta_map_name"
	local -n active_constraints_ref="$active_constraints_var_name"

	active_constraints_ref=()

	while IFS=$'	' read -r token base; do
		[[ -n "$token" && "$base" =~ ^[0-9]+$ ]] || continue
		adjusted=$((base + ${delta_ref[$token]:-0}))
		((adjusted >= 0)) || adjusted=0

		if [[ -z "$best_value" ]] || ((adjusted < best_value)); then
			best_value="$adjusted"
			active_constraints_ref=("$token")
		elif ((adjusted == best_value)); then
			active_constraints_ref+=("$token")
		fi
	done < <(emit_dataset_capacity_constraints "$dataset")

	if [[ -z "$best_value" ]]; then
		printf -v "$effective_var_name" ''
		return 1
	fi

	printf -v "$effective_var_name" '%s' "$best_value"
	return 0
}

get_dataset_effective_avail() {
	local dataset="$1"
	local delta_map_name="${2:-NO_CONSTRAINT_RECLAIM}"
	local effective_avail
	local -a active_constraints=()

	get_dataset_active_constraints "$dataset" "$delta_map_name" effective_avail active_constraints || {
		echo ""
		return 1
	}

	echo "$effective_avail"
}

dataset_is_within_scope() {
	local dataset="$1"
	local scope="$2"

	[[ "$dataset" == "$scope" || "$dataset" == "$scope/"* ]]
}

candidate_affects_constraint() {
	local dataset="$1"
	local constraint="$2"
	local scope

	case "$constraint" in
	pool:*)
		[[ "${dataset%%/*}" == "${constraint#pool:}" ]]
		return
		;;
	quota:*)
		scope="${constraint#quota:}"
		dataset_is_within_scope "$dataset" "$scope"
		return
		;;
	refquota:*)
		# Snapshot deletion does not reliably improve refquota headroom, so treat
		# refquota-limited datasets as non-benefiting for cross-dataset cleanup.
		return 1
		;;
	esac

	return 1
}

candidate_affects_any_constraint() {
	local dataset="$1"
	local constraints_var_name="$2"
	local constraint
	local -n constraints_ref="$constraints_var_name"

	for constraint in "${constraints_ref[@]}"; do
		if candidate_affects_constraint "$dataset" "$constraint"; then
			return 0
		fi
	done

	return 1
}

apply_simulated_reclaim_to_constraints() {
	local dataset="$1"
	local reclaimed_bytes="$2"
	local delta_map_name="$3"
	local pool="${dataset%%/*}"
	local current quota
	local -n delta_ref="$delta_map_name"

	((reclaimed_bytes > 0)) || return 0

	delta_ref["pool:${pool}"]=$(( ${delta_ref["pool:${pool}"]:-0} + reclaimed_bytes ))

	current="$dataset"
	while :; do
		quota="$(get_dataset_numeric_property "$current" "quota")"
		if ((quota > 0)); then
			delta_ref["quota:${current}"]=$(( ${delta_ref["quota:${current}"]:-0} + reclaimed_bytes ))
		fi

		[[ "$current" == "$pool" ]] && break
		current="${current%/*}"
	done
}

format_constraint_list() {
	local constraints_var_name="$1"
	local -n constraints_ref="$constraints_var_name"
	local constraint joined=""

	for constraint in "${constraints_ref[@]}"; do
		if [[ -n "$joined" ]]; then
			joined+=", "
		fi
		joined+="$constraint"
	done

	printf '%s\n' "$joined"
}

find_oldest_reclaimable_snapshot_for_constraints() {
	local constraints_var_name="$1"
	local result_snap_var_name="$2"
	local result_dataset_var_name="$3"
	local result_used_var_name="$4"
	local result_any_snapshots_var_name="$5"
	local count_skips="${6:-1}"
	local candidate_ds candidate_snap candidate_epoch candidate_used
	local selected_snap="" selected_snap_epoch="" selected_dataset="" selected_used=0 found_candidate_snapshots=0

	for pair in "${pairs[@]}"; do
		candidate_ds="${pair%:*}"
		if ! candidate_affects_any_constraint "$candidate_ds" "$constraints_var_name"; then
			continue
		fi

		ensure_dataset_cleanup_candidate "$candidate_ds" "$count_skips"

		if (( ${LOW_SPACE_DATASET_ANY_SNAPS[$candidate_ds]:-0} > 0 )); then
			found_candidate_snapshots=1
		fi

		candidate_snap="${LOW_SPACE_DATASET_CANDIDATE_SNAP[$candidate_ds]:-}"
		candidate_epoch="${LOW_SPACE_DATASET_CANDIDATE_EPOCH[$candidate_ds]:-}"
		candidate_used="${LOW_SPACE_DATASET_CANDIDATE_USED[$candidate_ds]:-0}"
		[[ -n "$candidate_snap" && -n "$candidate_epoch" ]] || continue

		if [[ -z "$selected_snap_epoch" || "$candidate_epoch" -lt "$selected_snap_epoch" ]]; then
			selected_snap="$candidate_snap"
			selected_snap_epoch="$candidate_epoch"
			selected_dataset="$candidate_ds"
			selected_used="$candidate_used"
		fi
	done

	printf -v "$result_snap_var_name" '%s' "$selected_snap"
	printf -v "$result_dataset_var_name" '%s' "$selected_dataset"
	printf -v "$result_used_var_name" '%s' "$selected_used"
	printf -v "$result_any_snapshots_var_name" '%s' "$found_candidate_snapshots"
}

set_low_space_unresolved_state() {
	local datasets_state="$1"
	local notes_state="$2"
	local unresolved_count

	LOW_SPACE_UNRESOLVED_POOLS="$datasets_state"
	LOW_SPACE_UNRESOLVED_NOTES="$notes_state"
	unresolved_count="$(emit_newline_entries "$datasets_state" | wc -l | tr -d '[:space:]')"
	if [[ -n "$unresolved_count" && "$unresolved_count" =~ ^[0-9]+$ ]]; then
		COUNT_LOW_SPACE_UNRESOLVED="$unresolved_count"
	else
		COUNT_LOW_SPACE_UNRESOLVED=0
	fi
}

pick_oldest_snapshot() {
	local snapshot_lines="$1"

	# Find the minimum creation epoch without sort|head to avoid SIGPIPE exits
	# under "set -o pipefail" when only the first row is needed.
	printf '%s\n' "$snapshot_lines" | awk -F '\t' '
    NF >= 2 && $2 ~ /^[0-9]+$/ {
      if (!found || $2 < min_epoch) {
        min_epoch = $2
        oldest_snap = $1
        found = 1
      }
    }
    END {
      if (found) print oldest_snap
    }
  '
}

prune_log_to_last_runs() {
	local file="$1"
	local marker="$2"
	local keep_runs="$3"
	local start_line tmp

	[[ -f "$file" ]] || return 0
	[[ "$keep_runs" =~ ^[0-9]+$ ]] || return 0
	((keep_runs >= 1)) || return 0

	start_line="$(awk -v marker="$marker" -v keep="$keep_runs" '
    index($0, marker) == 1 { marks[++count] = NR }
    END {
      if (count >= keep) print marks[count - keep + 1];
      else print 1;
    }
  ' "$file" 2>/dev/null || echo 1)"

	[[ "$start_line" =~ ^[0-9]+$ ]] || start_line=1

	tmp="$(mktemp "${file}.tmp.XXXXXX")" || return 0
	if ! sed -n "${start_line},\$p" "$file" >"$tmp" 2>/dev/null; then
		rm -f "$tmp"
		return 0
	fi

	if : >"$file" 2>/dev/null; then
		cat "$tmp" >"$file" 2>/dev/null || true
	fi

	rm -f "$tmp"
}

write_run_summary() {
	local exit_code="$1"
	local ended_at_human now_epoch duration_seconds tmp_file
	local created_label deleted_label

	[[ -n "$RUN_STARTED_AT_HUMAN" ]] || return 0

	ended_at_human="$(date +'%Y-%m-%d %H:%M:%S %Z')"
	now_epoch="$(date +%s)"
	duration_seconds=$((now_epoch - RUN_STARTED_AT_EPOCH))

	if ((DRY_RUN)); then
		created_label="Snapshots planned to create"
		deleted_label="Snapshots planned to delete"
	else
		created_label="Snapshots created"
		deleted_label="Snapshots deleted"
	fi

	tmp_file="$(mktemp "${SUMMARY_LOG_FILE}.tmp.XXXXXX")" || return 0

	{
		echo "ZFS Auto Snapshot - Latest Run Summary"
		echo "Started: ${RUN_STARTED_AT_HUMAN}"
		echo "Finished: ${ended_at_human}"
		echo "Duration: ${duration_seconds}s"
		echo "Mode: ${RUN_MODE}"

		if ((exit_code == 0)); then
			echo "Result: Success"
		else
			echo "Result: Failed (exit code ${exit_code})"
			echo "What went wrong: ${RUN_USER_ERROR:-The run stopped due to an unexpected internal error.}"
			echo "What to do: ${RUN_USER_ACTION:-Open the Debug Log, fix the issue, then run again.}"
			if [[ -n "$RUN_ERROR_CONTEXT" ]]; then
				echo "Failure point: ${RUN_ERROR_CONTEXT}"
			fi
		fi

		echo "Datasets configured: ${RUN_DATASET_COUNT}"
		echo "Pools evaluated: ${RUN_POOL_COUNT}"
		echo
		echo "${created_label}: ${COUNT_CREATED}"
		echo "${deleted_label}: ${COUNT_DELETED_TOTAL}"
		echo "  Deleted by age retention (outside oldest window): ${COUNT_DELETED_AGE}"
		echo "  Deleted by daily consolidation: ${COUNT_DELETED_DAILY}"
		echo "  Deleted by weekly consolidation: ${COUNT_DELETED_WEEKLY}"
		echo "  Deleted by low-space cleanup: ${COUNT_DELETED_SPACE}"
		echo "  Deleted as zero-change housekeeping: ${COUNT_DELETED_ZERO_CHANGE}"
		echo "Skipped because held or leased: ${COUNT_SKIPPED_HELD}"
			echo "Skipped because snapshot had no immediate reclaim path: ${COUNT_SKIPPED_NON_RECLAIMABLE}"
		echo "Datasets left below target because reclaim is blocked: ${COUNT_LOW_SPACE_UNRESOLVED}"

		if ((COUNT_LOW_SPACE_UNRESOLVED > 0)); then
			echo
			echo "Warnings:"
				echo "  Some datasets stayed below their configured free-space target because no deletable auto-snapshot chain could safely improve them."
			while IFS= read -r note; do
				[[ -n "$note" ]] || continue
				echo "  ${note}"
			done <<<"$(emit_newline_entries "$LOW_SPACE_UNRESOLVED_NOTES")"
		fi
	} >"$tmp_file"

	if mv -f "$tmp_file" "$SUMMARY_LOG_FILE" 2>/dev/null; then
		chmod 0600 "$SUMMARY_LOG_FILE" 2>/dev/null || true
		chown root:root "$SUMMARY_LOG_FILE" 2>/dev/null || true
	else
		rm -f "$tmp_file"
	fi
}

on_exit() {
	local exit_code="$?"
	set +e

	if ((LOCK_FALLBACK_HELD)); then
		rmdir "$LOCKDIR" 2>/dev/null || true
	fi

	if ((RUN_SUMMARY_ENABLED)); then
		write_run_summary "$exit_code" || true
		prune_log_to_last_runs "$LOG_FILE" "$LOG_RUN_MARKER" "$KEEP_LOG_RUNS" || true
	fi
}

# -----------------------------------------------------------------------------
# Acquire exclusive lock (non-blocking)
#   Prefer flock. Fallback to mkdir lock if flock is unavailable.
# -----------------------------------------------------------------------------
acquire_lock() {
	if command -v flock >/dev/null 2>&1; then
		exec 200>"$LOCKFILE"
		if ! flock -n 200; then
			log "Another instance is already running (lock: $LOCKFILE). Exiting."
			exit 0
		fi
		echo "$$" 1>&200
	else
		if ! mkdir "$LOCKDIR" 2>/dev/null; then
			log "Another instance is already running (lock: $LOCKDIR). Exiting."
			exit 0
		fi
		echo "$$" >"$LOCKDIR/pid"
		LOCK_FALLBACK_HELD=1
	fi
}

# -----------------------------------------------------------------------------
# Time-based retention cleanup for one dataset
# -----------------------------------------------------------------------------
time_clean_dataset() {
	local ds="$1"
	log "Time-based cleanup for dataset: $ds"

	# Output format: name<TAB>creation_epoch (newest first)
	local snaps
	local protection_reason written_raw written_bytes userrefs_raw used_raw used_bytes
	local zero_change_anchor=""
	local latest_snapshot=""
	local -A snap_written_map=()
	local -A snap_userrefs_map=()
	snaps="$(zfs list -H -p -t snapshot -o name,creation -S creation -r "$ds" | grep -F "@${PREFIX}" || true)"

	if [[ -z "$snaps" ]]; then
		log "  No ${PREFIX} snapshots found."
		return 0
	fi

	declare -A snap_used_map=()
	load_snapshot_property_maps "$ds" snap_used_map snap_written_map snap_userrefs_map

	# Keep seen day/week keys in newline-delimited sets for broad Bash compatibility.
	local kept_day=$'\n'
	local kept_week=$'\n'

	while IFS=$'\t' read -r snap_name snap_created; do
		[[ -z "$snap_name" || -z "$snap_created" ]] && continue

		written_raw="${snap_written_map[$snap_name]:-}"
		written_bytes="$(snapshot_numeric_property "$written_raw" -1)"
		used_raw="${snap_used_map[$snap_name]:-0}"
		used_bytes="$(snapshot_numeric_property "$used_raw" 0)"
		userrefs_raw="${snap_userrefs_map[$snap_name]:-0}"
		protection_reason="$(snapshot_protection_reason "$snap_name" "$userrefs_raw" || true)"

		if [[ -z "$latest_snapshot" ]]; then
			latest_snapshot="$snap_name"
			remember_protected_latest_snapshot "$snap_name"
			if ((written_bytes == 0)); then
				zero_change_anchor="$snap_name"
			else
				zero_change_anchor=""
			fi
			log "  Keeping newest autosnapshot: $snap_name"
			continue
		fi

		if ((written_bytes == 0)); then
			if [[ -n "$zero_change_anchor" ]]; then
				if [[ -n "$protection_reason" ]]; then
					log "  Keeping zero-change duplicate because it is ${protection_reason}: $snap_name"
					record_skipped_held_snapshot "$snap_name"
				else
					log "  Deleting zero-change duplicate: $snap_name (used=${used_bytes})"
					do_destroy "$snap_name" "zero_change_housekeeping"
				fi
				continue
			fi
			zero_change_anchor="$snap_name"
		else
			zero_change_anchor=""
		fi

		local age=$((NOW_EPOCH - snap_created))

		if ((age > KEEP_WEEKLY_UNTIL_SECONDS)); then
			if [[ -n "$protection_reason" ]]; then
				log "  Keeping expired snapshot because it is ${protection_reason}: $snap_name"
				record_skipped_held_snapshot "$snap_name"
			else
				log "  Deleting (older than ${KEEP_WEEKLY_UNTIL_DAYS}d): $snap_name"
				do_destroy "$snap_name" "age_window"
			fi
			continue
		fi

		if ((age > KEEP_DAILY_UNTIL_SECONDS)); then
			local week_key
			week_key="$(date -d @"$snap_created" +%Y-%W)"
			if [[ "$kept_week" != *$'\n'"$week_key"$'\n'* ]]; then
				kept_week+="$week_key"$'\n'
				log "  Keeping weekly latest: $snap_name"
			else
				if [[ -n "$protection_reason" ]]; then
					log "  Keeping weekly duplicate because it is ${protection_reason}: $snap_name"
					record_skipped_held_snapshot "$snap_name"
				else
					log "  Deleting weekly duplicate: $snap_name"
					do_destroy "$snap_name" "weekly_consolidation"
				fi
			fi
			continue
		fi

		if ((age > KEEP_ALL_FOR_SECONDS)); then
			local day_key
			day_key="$(date -d @"$snap_created" +%Y-%m-%d)"
			if [[ "$kept_day" != *$'\n'"$day_key"$'\n'* ]]; then
				kept_day+="$day_key"$'\n'
				log "  Keeping daily latest: $snap_name"
			else
				if [[ -n "$protection_reason" ]]; then
					log "  Keeping daily duplicate because it is ${protection_reason}: $snap_name"
					record_skipped_held_snapshot "$snap_name"
				else
					log "  Deleting daily duplicate: $snap_name"
					do_destroy "$snap_name" "daily_consolidation"
				fi
			fi
			continue
		fi

		log "  Keeping recent: $snap_name"
	done <<<"$snaps"
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------
if [[ -f "$CONFIG_FILE" ]]; then
	load_config_file "$CONFIG_FILE"
fi

trap 'record_error_context "$LINENO" "$BASH_COMMAND"' ERR
trap on_exit EXIT

RUN_SUMMARY_ENABLED=1
RUN_STARTED_AT_EPOCH="$(date +%s)"
RUN_STARTED_AT_HUMAN="$(date +'%Y-%m-%d %H:%M:%S %Z')"
RUN_MODE="normal"
if [[ "$DRY_RUN" == "1" ]]; then
	RUN_MODE="dry-run"
fi

DATASETS="$(trim "$DATASETS")"
PREFIX="$(trim "$PREFIX")"
KEEP_LOG_RUNS="$(trim "$KEEP_LOG_RUNS")"
POST_DELETE_RECHECK_WAIT_SECONDS="$(trim "$POST_DELETE_RECHECK_WAIT_SECONDS")"
POST_DELETE_RECHECK_INTERVAL_SECONDS="$(trim "$POST_DELETE_RECHECK_INTERVAL_SECONDS")"

if [[ -z "$PREFIX" ]]; then
	fail_config "Snapshot prefix is empty, which is unsafe." "Set a non-empty prefix (example: autosnapshot-) so only this plugin's snapshots can be deleted."
fi

if [[ "$PREFIX" == *"@"* ]]; then
	fail_config "Snapshot prefix cannot contain '@'." "Remove '@' from the prefix and save settings again."
fi

if [[ ! "$PREFIX" =~ ^[A-Za-z0-9._:-]+$ ]]; then
	fail_config "Snapshot prefix contains unsupported characters." "Use only letters, numbers, dot, underscore, colon, or dash in the prefix."
fi

if [[ "$DRY_RUN" != "0" && "$DRY_RUN" != "1" ]]; then
	fail_config "DRY_RUN must be 0 or 1." "Set DRY_RUN to 0 for live mode or 1 for preview mode."
fi

if [[ -z "$LOCKFILE" || -z "$LOCKDIR" ]]; then
	fail_config "Lock file settings are empty." "Reset lock settings to defaults and run again."
fi

if [[ -z "$LOG_FILE" || -z "$SUMMARY_LOG_FILE" ]]; then
	fail_config "Log file paths are empty." "Set valid paths for LOG_FILE and SUMMARY_LOG_FILE."
fi

require_numeric_in_range "KEEP_LOG_RUNS" "$KEEP_LOG_RUNS" 1 50
require_numeric_in_range "KEEP_ALL_FOR_DAYS" "$KEEP_ALL_FOR_DAYS" 1 36500
require_numeric_in_range "KEEP_DAILY_UNTIL_DAYS" "$KEEP_DAILY_UNTIL_DAYS" 2 36500
require_numeric_in_range "KEEP_WEEKLY_UNTIL_DAYS" "$KEEP_WEEKLY_UNTIL_DAYS" 3 36500
require_numeric_in_range "POST_DELETE_RECHECK_WAIT_SECONDS" "$POST_DELETE_RECHECK_WAIT_SECONDS" 0 300
require_numeric_in_range "POST_DELETE_RECHECK_INTERVAL_SECONDS" "$POST_DELETE_RECHECK_INTERVAL_SECONDS" 1 60

if ((POST_DELETE_RECHECK_INTERVAL_SECONDS > POST_DELETE_RECHECK_WAIT_SECONDS && POST_DELETE_RECHECK_WAIT_SECONDS > 0)); then
	fail_config "POST_DELETE_RECHECK_INTERVAL_SECONDS is longer than POST_DELETE_RECHECK_WAIT_SECONDS." "Lower the recheck interval or increase the total wait window."
fi

if ((KEEP_ALL_FOR_DAYS >= KEEP_DAILY_UNTIL_DAYS || KEEP_DAILY_UNTIL_DAYS >= KEEP_WEEKLY_UNTIL_DAYS)); then
	fail_config "Retention order is invalid." "Use this order: Keep all < Keep daily until < Keep weekly until."
fi

if ! command -v zfs >/dev/null 2>&1 || ! command -v zpool >/dev/null 2>&1; then
	fail_config "zfs/zpool commands are not available." "Install/enable ZFS on this server, then run again."
fi

prepare_runtime_state
acquire_lock

IFS=',' read -r -a raw_pairs <<<"$DATASETS"
declare -a pairs=()
for raw_pair in "${raw_pairs[@]}"; do
	pair="$(trim "$raw_pair")"
	[[ -z "$pair" ]] && continue

	if [[ "$pair" != *:* ]]; then
		fail_config "Bad DATASETS entry '$pair'." "Each entry must look like dataset:threshold (example: tank/media:100G)."
	fi

	ds="$(trim "${pair%:*}")"
	thresh="$(trim "${pair##*:}")"

	if [[ -z "$ds" || -z "$thresh" ]]; then
		fail_config "Bad DATASETS entry '$pair'." "Each entry must include both dataset and threshold."
	fi

	if [[ ! "$ds" =~ ^[A-Za-z0-9][A-Za-z0-9._/-]*$ ]]; then
		fail_config "Dataset name '$ds' contains unsupported characters." "Use standard ZFS dataset paths like pool/name or pool/path/name."
	fi

	pairs+=("$ds:$thresh")
done

if ((${#pairs[@]} == 0)); then
	fail_config "No datasets are configured." "Select at least one dataset in settings, then save."
fi

NOW_EPOCH="$(date +%s)"
KEEP_ALL_FOR_SECONDS=$((KEEP_ALL_FOR_DAYS * 86400))
KEEP_DAILY_UNTIL_SECONDS=$((KEEP_DAILY_UNTIL_DAYS * 86400))
KEEP_WEEKLY_UNTIL_SECONDS=$((KEEP_WEEKLY_UNTIL_DAYS * 86400))

load_active_leases

log "${LOG_RUN_MARKER} ts=$(date +'%Y-%m-%d %H:%M:%S %Z') pid=$$ mode=${RUN_MODE}"
log_runtime_environment
log "Config: datasets='${DATASETS}' prefix='${PREFIX}' dry_run=${DRY_RUN}"
log "Retention(days): keep_all=${KEEP_ALL_FOR_DAYS} keep_daily_until=${KEEP_DAILY_UNTIL_DAYS} keep_weekly_until=${KEEP_WEEKLY_UNTIL_DAYS}"
log "Post-delete recheck(seconds): wait=${POST_DELETE_RECHECK_WAIT_SECONDS} interval=${POST_DELETE_RECHECK_INTERVAL_SECONDS}"
log "Logs: debug='${LOG_FILE}' summary='${SUMMARY_LOG_FILE}'"
if [[ -f "$LEASE_STATE_FILE" ]]; then
	log "Leases: active snapshot-manager leases loaded from '${LEASE_STATE_FILE}'"
fi

declare -a pool_names=()

# Phase A: time-based cleanup + collect unique pools for reporting
for pair in "${pairs[@]}"; do
	ds="${pair%:*}"
	pool="${ds%%/*}"
	remember_pool_name "$pool"

	time_clean_dataset "$ds"
done

RUN_DATASET_COUNT="${#pairs[@]}"
RUN_POOL_COUNT="${#pool_names[@]}"
log "Prepared ${RUN_DATASET_COUNT} dataset entries across ${RUN_POOL_COUNT} pool(s)."

# Phase B: low-space cleanup using whichever capacity constraints currently limit
# the low dataset. If multiple constraints tie, any dataset that can improve any
# active constraint is eligible.
# shellcheck disable=SC2034  # tracked through nameref helpers
declare -A simulated_constraint_reclaimed_bytes=()
blocked_low_datasets=$'\n'
blocked_low_dataset_notes=$'\n'
simulated_deleted_snaps=$'\n'
LOW_SPACE_DATASET_SNAPSHOT_LINES=()
LOW_SPACE_DATASET_CANDIDATE_SNAP=()
LOW_SPACE_DATASET_CANDIDATE_USED=()
LOW_SPACE_DATASET_CANDIDATE_EPOCH=()
LOW_SPACE_DATASET_ANY_SNAPS=()
LOW_SPACE_DATASET_GENERATION=()
LOW_SPACE_DATASET_REFRESH_GENERATION=()

while :; do
	low_dataset=""
	low_dataset_threshold=0
	low_dataset_effective_avail=0
	low_dataset_active_constraints_display=""
	# shellcheck disable=SC2034  # passed by name into helper functions
	declare -a low_dataset_active_constraints=()

	for pair in "${pairs[@]}"; do
		ds="${pair%:*}"
		thresh="${pair##*:}"
		pool="${ds%%/*}"
		min_free="$(threshold_to_bytes "$thresh")"
		declare -a active_constraints=()

		if ! get_dataset_active_constraints "$ds" simulated_constraint_reclaimed_bytes effective_avail active_constraints; then
			log "Dataset $ds check failed: unable to read available space. Skipping low-space cleanup for this dataset."
			continue
		fi

		if ((effective_avail >= min_free)); then
			continue
		fi

		if newline_set_contains "$blocked_low_datasets" "$ds"; then
			continue
		fi

		low_dataset="$ds"
		low_dataset_threshold="$min_free"
		low_dataset_effective_avail="$effective_avail"
		# shellcheck disable=SC2034  # passed by name into helper functions
		low_dataset_active_constraints=("${active_constraints[@]}")
		low_dataset_active_constraints_display="$(format_constraint_list low_dataset_active_constraints)"
		break
	done

	[[ -n "$low_dataset" ]] || break

	log "Dataset $low_dataset is below its free-space target: effective_avail=${low_dataset_effective_avail} min_required=${low_dataset_threshold} active_constraints=${low_dataset_active_constraints_display}"

	oldest_snap=""
	oldest_snap_dataset=""
	oldest_snap_used=0
	oldest_snap_actual_dataset=""
	any_candidate_snapshots=0
	find_oldest_reclaimable_snapshot_for_constraints \
		low_dataset_active_constraints \
		oldest_snap \
		oldest_snap_dataset \
		oldest_snap_used \
		any_candidate_snapshots \
		1

	if ((any_candidate_snapshots == 0)); then
		log "Dataset $low_dataset is low on space, but no ${PREFIX} snapshots remain on datasets that can benefit it (active_constraints=${low_dataset_active_constraints_display})."
		remember_newline_entry blocked_low_datasets "$low_dataset" >/dev/null 2>&1 || true
		remember_newline_entry blocked_low_dataset_notes "$low_dataset: No ${PREFIX} snapshots remain on datasets that can improve ${low_dataset}." >/dev/null 2>&1 || true
		continue
	fi

	if [[ -z "$oldest_snap" ]]; then
		log "Dataset $low_dataset is low on space, but no deletable ${PREFIX} snapshot chains remain on datasets that can benefit it (active_constraints=${low_dataset_active_constraints_display})."
		remember_newline_entry blocked_low_datasets "$low_dataset" >/dev/null 2>&1 || true
		remember_newline_entry blocked_low_dataset_notes "$low_dataset: No deletable ${PREFIX} snapshot chains remain on datasets that can improve ${low_dataset}." >/dev/null 2>&1 || true
		continue
	fi

	oldest_snap_actual_dataset="${oldest_snap%@*}"
	log "Dataset $low_dataset low on space -> deleting oldest eligible snapshot: $oldest_snap (dataset=${oldest_snap_actual_dataset} used=${oldest_snap_used} active_constraints=${low_dataset_active_constraints_display})"
	do_destroy "$oldest_snap" "space_pressure"
	remember_newline_entry simulated_deleted_snaps "$oldest_snap" >/dev/null 2>&1 || true
	mark_cleanup_candidates_dirty_for_snapshot "$oldest_snap"

	if ((DRY_RUN)); then
		apply_simulated_reclaim_to_constraints "$oldest_snap_dataset" "$oldest_snap_used" simulated_constraint_reclaimed_bytes
		after_effective_avail="$(get_dataset_effective_avail "$low_dataset" simulated_constraint_reclaimed_bytes)"
		log "Dataset $low_dataset low on space -> [DRY_RUN] simulated effective free space after delete: ${after_effective_avail}"
	else
		after_effective_avail="$(get_dataset_effective_avail "$low_dataset")"
		if [[ -z "$after_effective_avail" ]]; then
			log "Dataset $low_dataset low on space -> unable to re-check available space after deleting $oldest_snap; marking it unresolved for now."
			remember_newline_entry blocked_low_datasets "$low_dataset" >/dev/null 2>&1 || true
			remember_newline_entry blocked_low_dataset_notes "$low_dataset: Available space could not be re-checked after deleting ${oldest_snap}." >/dev/null 2>&1 || true
			continue
		fi

		if ((after_effective_avail <= low_dataset_effective_avail && oldest_snap_used > 0)) && should_wait_for_post_delete_recheck "$low_dataset" low_dataset_active_constraints "$after_effective_avail" "$low_dataset_effective_avail"; then
			log "Dataset $low_dataset low on space -> waiting up to ${POST_DELETE_RECHECK_WAIT_SECONDS}s for free-space accounting to update after deleting $oldest_snap."
			waited=0
			while ((waited < POST_DELETE_RECHECK_WAIT_SECONDS)); do
				sleep "$POST_DELETE_RECHECK_INTERVAL_SECONDS"
				waited=$((waited + POST_DELETE_RECHECK_INTERVAL_SECONDS))
				after_effective_avail="$(get_dataset_effective_avail "$low_dataset")"
				[[ -n "$after_effective_avail" ]] || break
				if ((after_effective_avail > low_dataset_effective_avail)); then
					log "Dataset $low_dataset low on space -> effective free space updated after waiting (before=${low_dataset_effective_avail} after=${after_effective_avail})."
					break
				fi
			done
		fi

		if [[ -z "$after_effective_avail" ]]; then
			log "Dataset $low_dataset low on space -> unable to re-check available space after deleting $oldest_snap; marking it unresolved for now."
			remember_newline_entry blocked_low_datasets "$low_dataset" >/dev/null 2>&1 || true
			remember_newline_entry blocked_low_dataset_notes "$low_dataset: Available space could not be re-checked after deleting ${oldest_snap}." >/dev/null 2>&1 || true
			continue
		fi

		if ((after_effective_avail <= low_dataset_effective_avail)); then
			log "Dataset $low_dataset low on space -> visible free space did not rise after deleting $oldest_snap (before=${low_dataset_effective_avail} after=${after_effective_avail} used=${oldest_snap_used}); continuing because other datasets may still benefit ${low_dataset}."
		fi
	fi

	# A successful or simulated delete changes the current landscape, so re-check
	# all low datasets from scratch instead of keeping prior blocked state.
	blocked_low_datasets=$'\n'
	blocked_low_dataset_notes=$'\n'
done

set_low_space_unresolved_state "$blocked_low_datasets" "$blocked_low_dataset_notes"

# Phase C: create new snapshots
timestamp="$(date +%Y-%m-%d_%H-%M-%S)"

for pair in "${pairs[@]}"; do
	ds="${pair%:*}"
	skip_create_for=""
	while IFS= read -r unresolved_dataset; do
		[[ -n "$unresolved_dataset" ]] || continue
		# shellcheck disable=SC2034  # passed by name into helper functions
		declare -a unresolved_constraints=()
		if ! get_dataset_active_constraints "$unresolved_dataset" simulated_constraint_reclaimed_bytes unresolved_effective_avail unresolved_constraints; then
			continue
		fi
		if candidate_affects_any_constraint "$ds" unresolved_constraints; then
			skip_create_for="$unresolved_dataset"
			break
		fi
	done <<<"$(emit_newline_entries "$LOW_SPACE_UNRESOLVED_POOLS")"
	if [[ -n "$skip_create_for" ]]; then
		log "Skipping snapshot create for $ds because low-space dataset $skip_create_for still cannot be helped by deleting any managed snapshots."
		continue
	fi
	new_snap="$ds@${PREFIX}${timestamp}"
	log "Creating snapshot: $new_snap"
	do_snapshot "$new_snap"
done

log "Snapshot management complete."
